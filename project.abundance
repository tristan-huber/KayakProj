              "ioValue": "{   \"keelK\": [     1,     0,     1   ],   \"length\": 1000,   \"transom\": {     \"x\": 0,     \"depthTop\": 41.50490760803223,     \"dDepthBot\": 151.19446754455566,     \"transomRake\": 0   },   \"sheerPlan\": [     {       \"w\": [         0.964651285591772,         0.035348714408227955,         0       ],       \"y\": -1.80450439453125,       \"dx\": 0     },     {       \"w\": [         0.7486291655612998,         0.2513708258919268,         8.546773481274663e-9       ],       \"y\": 24.07421112060547,       \"dx\": 105.3428840637207     },     {       \"w\": [         0.21106577727754236,         0.7889236729993971,         0.000010549723060471194       ],       \"y\": 67.2055435180664,       \"dx\": 207.03035354614258     },     {       \"w\": [         0.001,         0.9980000000000001,         0.0009999999999998899       ],       \"y\": 87.41537094116211,       \"dx\": 184.7177505493164     },     {       \"w\": [         0.000999974371984932,         0.7656963090007971,         0.23330371662721794       ],       \"y\": 65.04901885986328,       \"dx\": 177.5855255126953     },     {       \"w\": [         0.0009999996180250232,         0.38114208681259754,         0.6178579135693775       ],       \"y\": 34.8570442199707,       \"dx\": 170.36880493164062     },     {       \"w\": [         0.00100000000030143,         0.047281919751120095,         0.9517180802485785       ],       \"y\": -5.360698699951172,       \"dx\": 181.4720916748047     }   ],   \"sheerTrim\": [     {       \"k\": 0,       \"dx\": 0,       \"depth\": 0     },     {       \"k\": 0,       \"dx\": 256.3025665283203,       \"depth\": 31.7159366607666     },     {       \"k\": 0,       \"dx\": 323.4849548339844,       \"depth\": 44.655303955078125     },     {       \"k\": 0,       \"dx\": 420.5304718017578,       \"depth\": 29.559402465820312     }   ],   \"templates\": [     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 1,         \"n\": 13.414994648524683,         \"dd\": 40.27403504507882       },       {         \"k\": 0,         \"n\": 32.124430792672285,         \"dd\": 79.51480756487165       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 1,         \"n\": 4.0603324345179885,         \"dd\": 68.33806637355259       },       {         \"k\": 0,         \"n\": 233.24999237060547,         \"dd\": 53.009864262172144       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 1,         \"n\": 7.178508486066534,         \"dd\": 57.42429379054478       },       {         \"k\": 0,         \"n\": 5.619420460292261,         \"dd\": 70.16011183602468       }     ]   ],   \"waterline\": 60,   \"deckRakeDeg\": 0 }",
              "currentEquation": "{   \"keelK\": [     0,     0,     1   ],   \"length\": 1000,   \"transom\": {     \"x\": 37.5,     \"depthTop\": 13.75,     \"dDepthBot\": 164.57321860573512,     \"transomRake\": 0.19040145970789402   },   \"sheerPlan\": [     {       \"w\": [         0.999,         0.0010000000000000009,         0       ],       \"y\": 83.05644989013672,       \"dx\": 0     },     {       \"w\": [         0.7081673032614589,         0.27963621393513216,         0.012196482803408883       ],       \"y\": 98.54542125355114,       \"dx\": 254.1132146661932     },     {       \"w\": [         0.5490735699449668,         0.3553395955276473,         0.09558683452738578       ],       \"y\": 104.35376600785689,       \"dx\": 243.95079179243606     },     {       \"w\": [         0.4755968523094466,         0.36706145295895043,         0.157341694731603       ],       \"y\": 83.05644989013672,       \"dx\": 247.82298694957387     },     {       \"w\": [         0,         0.1282900129045759,         0.8717099870954241       ],       \"y\": -16.880264282226562,       \"dx\": 300.3057861328125     }   ],   \"sheerTrim\": [     {       \"k\": 0,       \"dx\": 0,       \"depth\": 69.80532906272197     },     {       \"k\": 0,       \"dx\": 338.0096435546875,       \"depth\": 38.35085261951798     },     {       \"k\": 0,       \"dx\": 339.70815485174,       \"depth\": 27.34180970625448     },     {       \"k\": 0,       \"dx\": 422.2822015935725,       \"depth\": 35.85174560546875     }   ],   \"templates\": [     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": -3.361296963382074,         \"dd\": 68.0985029641684       },       {         \"k\": 1,         \"n\": 5.907469910460634,         \"dd\": 53.29617587002841       },       {         \"k\": 0,         \"n\": 22.127898327715997,         \"dd\": 4.6344335977133255       },       {         \"k\": 0,         \"n\": 49.934600235579865,         \"dd\": 23.172268310150542       },       {         \"k\": 0,         \"n\": 184.72228855281685,         \"dd\": 6.707857800768579       },       {         \"k\": 0,         \"n\": 259.99087544230673,         \"dd\": 0       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": 3.590386873715886,         \"dd\": 98.22239937720362       },       {         \"k\": 1,         \"n\": 5.907469910460634,         \"dd\": 41.710058435217135       },       {         \"k\": 0,         \"n\": 19.81081529097125,         \"dd\": 4.634489331926602       },       {         \"k\": 0,         \"n\": 59.20380183628629,         \"dd\": 76.46843303333631       },       {         \"k\": 0,         \"n\": 124.08596137901407,         \"dd\": 41.710080728902454       },       {         \"k\": 0,         \"n\": 124.08596137901407,         \"dd\": 0       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": -13.222641139835503,         \"dd\": 57.90226304685915       },       {         \"k\": 0,         \"n\": -14.871515546526226,         \"dd\": 42.869341218626346       },       {         \"k\": 0,         \"n\": -13.222641139835503,         \"dd\": 34.62523670939656       },       {         \"k\": 0,         \"n\": -4.978581217976355,         \"dd\": 36.27407767555931       },       {         \"k\": 0,         \"n\": 237.62986319405695,         \"dd\": 56.31614536434026       },       {         \"k\": 0,         \"n\": 237.62986319405695,         \"dd\": 0       }     ]   ],   \"waterline\": 150,   \"deckRakeDeg\": 0 }"
