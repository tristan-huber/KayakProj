          ],
          "interpreterVersion": 1,
          "code": "/**\n * Develops (flattens) a ruled surface into a 2D Drawing of its boundary.\n *\n * Input must be an Assembly containing a single replicad.Face — typically the\n * side face of a ruled loft. The atom samples `numRulings + 1` straight-line\n * generators across the surface (clipped to the face's trimmed outer wire),\n * then unfolds the resulting quad strip triangle-by-triangle into the plane\n * using rigid (length-preserving) edges. The returned Drawing is the closed\n * boundary of the flattened pattern, with any inner wires (holes) on the\n * source face punched out of the result.\n *\n *   rulingAxis === \"U\" / \"V\" / \"auto\" — same conventions as the rulings atom.\n *   seamAtStart === true → first ruling lies along +X in the 2D pattern;\n *                          rest of the pattern unfolds toward +Y.\n *   boundarySamples       → number of points used to approximate the trimmed\n *                          outer wire as a UV polyline. Increase if a curved\n *                          boundary (e.g. a small-radius arc) is being clipped\n *                          inaccurately; decrease for faster execution.\n *   holeSamples           → number of samples per inner wire (hole). Each hole\n *                          becomes a polygon with this many sides in the 2D\n *                          pattern; raise for smoother curves.\n *\n * If the surface is not developable at a particular strip (the four edge\n * lengths don't admit a planar quad) the atom throws an explicit error\n * naming the strip index.\n */\nfunction run(\n  surface: Assembly,\n  numRulings: number = 24,\n  rulingAxis: string = \"auto\",\n  seamAtStart: boolean = true,\n  boundarySamples: number = 256,\n  holeSamples: number = 64,\n) {\n  // ── Step 1: Validate input is a single Face ───────────────────────────────\n  if (!surface || !surface.isLeaf || !surface.isLeaf()) {\n    throw new Error(\n      \"Develop surface: input must be an Assembly with exactly one leaf \" +\n      \"(the ruled surface as a replicad.Face).\",\n    );\n  }\n  const face = surface.geometry as any;\n  if (!(face instanceof replicad.Face)) {\n    throw new Error(\n      \"Develop surface: input geometry must be a replicad.Face from a ruled \" +\n      \"loft; got \" +\n      (face && face.constructor ? face.constructor.name : typeof face),\n    );\n  }\n  if (!Number.isFinite(numRulings) || numRulings < 1) {\n    throw new Error(\"Develop surface: numRulings must be a positive integer.\");\n  }\n  if (!Number.isFinite(boundarySamples) || boundarySamples < 8) {\n    throw new Error(\n      \"Develop surface: boundarySamples must be an integer ≥ 8 (used to \" +\n      \"approximate the trimmed outer wire as a UV polyline).\",\n    );\n  }\n  if (!Number.isFinite(holeSamples) || holeSamples < 8) {\n    throw new Error(\n      \"Develop surface: holeSamples must be an integer ≥ 8 (used to \" +\n      \"approximate each inner wire as a polygon in the 2D pattern).\",\n    );\n  }\n  const n = Math.max(1, Math.floor(numRulings));\n  const boundaryN = Math.max(8, Math.floor(boundarySamples));\n  const holeN = Math.max(8, Math.floor(holeSamples));\n\n  const { uMin, uMax, vMin, vMax } = face.UVBounds;\n\n  type T3 = [number, number, number];\n  type T2 = [number, number];\n\n  // IMPORTANT: replicad's face.pointOnSurface(u, v) takes NORMALISED\n  // parameters in [0, 1] (internally it computes uMin + u*(uMax-uMin)), while\n  // face.UVBounds and face.uvCoordinates(...) return ABSOLUTE OCCT parameter\n  // values. We use absolute params everywhere outside this helper so the\n  // clipping math stays consistent with uvCoordinates() output, and convert\n  // to normalised here at the actual call to pointOnSurface.\n  const uSpan = uMax - uMin;\n  const vSpan = vMax - vMin;\n  const sampleTuple = (uAbs: number, vAbs: number): T3 => {\n    const uN = uSpan === 0 ? 0 : (uAbs - uMin) / uSpan;\n    const vN = vSpan === 0 ? 0 : (vAbs - vMin) / vSpan;\n    const p = face.pointOnSurface(uN, vN);\n    return [p.x, p.y, p.z];\n  };\n\n  // ── Step 2: Auto-detect / validate the ruling axis ───────────────────────\n  // Same heuristic as the rulings atom: an iso-curve is \"straight\" when the\n  // midpoint sag is negligible relative to the chord length.\n  const STRAIGHT_TOL = 1e-4;\n  const isStraightAlong = (which: \"U\" | \"V\"): boolean => {\n    const cross =\n      which === \"U\" ? vMin + 0.5 * (vMax - vMin) : uMin + 0.5 * (uMax - uMin);\n    const a = which === \"U\" ? uMin : vMin;\n    const b = which === \"U\" ? uMax : vMax;\n    const get = (t: number) =>\n      which === \"U\" ? sampleTuple(t, cross) : sampleTuple(cross, t);\n    const p0 = get(a);\n    const pm = get(0.5 * (a + b));\n    const p1 = get(b);\n    const dx = p1[0] - p0[0],\n      dy = p1[1] - p0[1],\n      dz = p1[2] - p0[2];\n    const chord = Math.hypot(dx, dy, dz);\n    if (chord === 0) return false;\n    const tx = pm[0] - p0[0],\n      ty = pm[1] - p0[1],\n      tz = pm[2] - p0[2];\n    const cx = dy * tz - dz * ty;\n    const cy = dz * tx - dx * tz;\n    const cz = dx * ty - dy * tx;\n    const perp = Math.hypot(cx, cy, cz) / chord;\n    return perp / chord < STRAIGHT_TOL;\n  };\n\n  let axis: \"U\" | \"V\";\n  if (rulingAxis === \"U\" || rulingAxis === \"V\") {\n    axis = rulingAxis;\n  } else if (rulingAxis === \"auto\") {\n    if (isStraightAlong(\"V\")) axis = \"V\";\n    else if (isStraightAlong(\"U\")) axis = \"U\";\n    else\n      throw new Error(\n        \"Develop surface: auto-detect failed — surface is not straight along \" +\n        \"either parametric axis. Override with rulingAxis: 'U' or 'V'.\",\n      );\n  } else {\n    throw new Error(\n      'Develop surface: rulingAxis must be \"auto\", \"U\", or \"V\"; got ' +\n      JSON.stringify(rulingAxis),\n    );\n  }\n\n  // ── Step 3: Sample the trimmed boundary in UV space ──────────────────────\n  // face.pointOnSurface() walks the underlying parametric surface, which can\n  // extend well beyond the actual trimmed face — e.g. a conical loft's\n  // underlying surface continues toward its apex below the bottom circle.\n  // We follow face.outerWire() in UV space and use it to clip each ruling to\n  // the trimmed region.\n  const outerWire = face.clone().outerWire();\n  const uvBoundary: T2[] = [];\n  for (let i = 0; i < boundaryN; i++) {\n    const t = i / boundaryN;\n    const p3d = outerWire.pointAt(t);\n    const uv = face.uvCoordinates(p3d);\n    uvBoundary.push([uv[0], uv[1]]);\n  }\n\n  // Indices into a [u, v] tuple for the cross-axis (perpendicular to rulings)\n  // vs the along-axis (parallel to rulings).\n  //   axis === \"V\": rulings sweep V; cross-axis is U  → crossIdx=0, alongIdx=1\n  //   axis === \"U\": rulings sweep U; cross-axis is V  → crossIdx=1, alongIdx=0\n  const crossIdx = axis === \"V\" ? 0 : 1;\n  const alongIdx = 1 - crossIdx;\n\n  // Actual cross-axis extent of the trimmed boundary.\n  let crossMinActual = Infinity;\n  let crossMaxActual = -Infinity;\n  for (const uv of uvBoundary) {\n    if (uv[crossIdx] < crossMinActual) crossMinActual = uv[crossIdx];\n    if (uv[crossIdx] > crossMaxActual) crossMaxActual = uv[crossIdx];\n  }\n  const crossSpan = crossMaxActual - crossMinActual;\n  if (!(crossSpan > 0)) {\n    throw new Error(\n      \"Develop surface: trimmed boundary has zero extent on the cross-axis.\",\n    );\n  }\n\n  // Intersect the iso-line \"cross-axis = crossParam\" with the closed UV\n  // polyline and return [alongMin, alongMax] — the actual along-axis extent\n  // of the trimmed face at that cross-axis value.\n  const rulingRange = (crossParam: number): [number, number] => {\n    const hits: number[] = [];\n    const N = uvBoundary.length;\n    for (let j = 0; j < N; j++) {\n      const a = uvBoundary[j];\n      const b = uvBoundary[(j + 1) % N];\n      const aC = a[crossIdx];\n      const bC = b[crossIdx];\n      if (aC === bC) continue;\n      // Skip seam wraparounds on periodic surfaces: a segment that jumps\n      // more than half the cross-axis span is almost certainly the U=0 ↔ U=2π\n      // discontinuity, not a real boundary edge.\n      if (Math.abs(bC - aC) > 0.5 * crossSpan) continue;\n      // Half-open straddle so a vertex lying exactly on the iso-line is\n      // counted by exactly one of its two incident segments.\n      const straddles =\n        (aC <= crossParam && bC > crossParam) ||\n        (bC <= crossParam && aC > crossParam);\n      if (!straddles) continue;\n      const t = (crossParam - aC) / (bC - aC);\n      hits.push(a[alongIdx] + t * (b[alongIdx] - a[alongIdx]));\n    }\n    if (hits.length < 2) {\n      throw new Error(\n        `Develop surface: cross-axis ${axis === \"V\" ? \"U\" : \"V\"}=` +\n        `${crossParam.toFixed(4)} intersects the outer wire at ` +\n        `${hits.length} point(s) (expected ≥2). The boundary may be ` +\n        `degenerate at this parameter, or boundarySamples may be too low ` +\n        `to resolve it.`,\n      );\n    }\n    hits.sort((a, b) => a - b);\n    return [hits[0], hits[hits.length - 1]];\n  };\n\n  // ── Step 4: Sample the two 3D rails using clipped iso-line ranges ────────\n  const railA: T3[] = [];\n  const railB: T3[] = [];\n  // Per-ruling absolute UV values, retained so the hole-mapping helper below\n  // can reconstruct the strip's clip range at any cross-axis parameter.\n  const crossParamArr: number[] = [];\n  const alongLowArr: number[] = [];\n  const alongHighArr: number[] = [];\n  for (let i = 0; i <= n; i++) {\n    const t = i / n;\n    let crossParam = crossMinActual + t * crossSpan;\n    // Nudge the very first and last samples a hair inward so the iso-line\n    // genuinely crosses the boundary polygon (it may be tangent at the\n    // extreme cross-axis values, giving <2 hits otherwise).\n    if (i === 0) crossParam += crossSpan * 1e-6;\n    if (i === n) crossParam -= crossSpan * 1e-6;\n    const [alongLow, alongHigh] = rulingRange(crossParam);\n    const aU = axis === \"V\" ? crossParam : alongLow;\n    const aV = axis === \"V\" ? alongLow : crossParam;\n    const bU = axis === \"V\" ? crossParam : alongHigh;\n    const bV = axis === \"V\" ? alongHigh : crossParam;\n    railA.push(sampleTuple(aU, aV));\n    railB.push(sampleTuple(bU, bV));\n    crossParamArr.push(crossParam);\n    alongLowArr.push(alongLow);\n    alongHighArr.push(alongHigh);\n  }\n\n  const dist3 = (p: T3, q: T3) =>\n    Math.hypot(p[0] - q[0], p[1] - q[1], p[2] - q[2]);\n\n  // ── Step 5: 2D unfold ─────────────────────────────────────────────────────\n  // Each quad has corners A[i], A[i+1], B[i+1], B[i]. We split it along the\n  // diagonal A[i+1]–B[i] into two triangles; rigid edge lengths in 3D become\n  // identical edge lengths in 2D. circleIntersect places the new vertex by\n  // intersecting two circles centred on already-placed vertices.\n  //\n  // sideSign = +1 places the result on the LEFT of the directed line p0→p1\n  //            (rotating (p1-p0) by +90° gives the +sideSign half-plane).\n  const CIRCLE_EPS = 1e-6;\n  const circleIntersect = (\n    p0: T2,\n    r0: number,\n    p1: T2,\n    r1: number,\n    sideSign: number,\n    stripIdx: number,\n  ): T2 => {\n    const dx = p1[0] - p0[0];\n    const dy = p1[1] - p0[1];\n    const d = Math.hypot(dx, dy);\n    const sum = r0 + r1;\n    const diff = Math.abs(r0 - r1);\n    if (d === 0 || d > sum * (1 + CIRCLE_EPS) || d < diff * (1 - CIRCLE_EPS)) {\n      throw new Error(\n        `Develop surface: non-flattenable quad at strip ${stripIdx} ` +\n        `(circles r0=${r0.toFixed(4)}, r1=${r1.toFixed(4)}, ` +\n        `centre-distance=${d.toFixed(4)}). The ruled surface is not ` +\n        `developable here — try a different rulingAxis, or accept that ` +\n        `this loft cannot be flattened without distortion.`,\n      );\n    }\n    // Clamp for numerical stability when d is right at the boundary.\n    const dC = Math.max(diff, Math.min(sum, d));\n    const a = (r0 * r0 - r1 * r1 + dC * dC) / (2 * dC);\n    const h = Math.sqrt(Math.max(0, r0 * r0 - a * a));\n    const ux = dx / d;\n    const uy = dy / d;\n    const mx = p0[0] + a * ux;\n    const my = p0[1] + a * uy;\n    // Perpendicular (left-hand rotation by +90°) scaled by sideSign.\n    return [mx + h * -uy * sideSign, my + h * ux * sideSign];\n  };\n\n  const cross2 = (a: T2, b: T2) => a[0] * b[1] - a[1] * b[0];\n  const sub2 = (a: T2, b: T2): T2 => [a[0] - b[0], a[1] - b[1]];\n\n  const A2: T2[] = new Array(n + 1);\n  const B2: T2[] = new Array(n + 1);\n\n  const lenR0 = dist3(railA[0], railB[0]);\n  A2[0] = [0, 0];\n  B2[0] = seamAtStart ? [lenR0, 0] : [0, lenR0];\n\n  for (let i = 0; i < n; i++) {\n    const lenAi = dist3(railA[i], railA[i + 1]);\n    const lenBi = dist3(railB[i], railB[i + 1]);\n    const lenRn = dist3(railA[i + 1], railB[i + 1]);\n    const diag = dist3(railA[i + 1], railB[i]);\n\n    // Place A2[i+1]: triangle (A2[i], B2[i], A2[i+1]) with sides lenR_i, diag, lenAi.\n    // For i=0 we pick the LEFT side (sideSign=+1) so the pattern unfolds toward\n    // the positive perpendicular of B2[0]→A2[0]. For i>=1 we pick the side\n    // OPPOSITE A2[i-1] so successive strips advance forward instead of folding.\n    let signA: number;\n    if (i === 0) {\n      signA = 1;\n    } else {\n      const prev = Math.sign(\n        cross2(sub2(B2[i], A2[i]), sub2(A2[i - 1], A2[i])),\n      );\n      signA = -prev || 1;\n    }\n    A2[i + 1] = circleIntersect(A2[i], lenAi, B2[i], diag, signA, i);\n\n    // Place B2[i+1]: triangle (A2[i+1], B2[i], B2[i+1]) with sides lenRn, lenBi, diag.\n    // Pick the side OPPOSITE A2[i] so the quad doesn't fold across its diagonal.\n    const sideOfAi = Math.sign(\n      cross2(sub2(B2[i], A2[i + 1]), sub2(A2[i], A2[i + 1])),\n    );\n    const signB = -sideOfAi || 1;\n    B2[i + 1] = circleIntersect(A2[i + 1], lenRn, B2[i], lenBi, signB, i);\n  }\n\n  // ── Step 5b: Developability quality metrics ──────────────────────────────\n  // Both metrics are per-quad (n quads for n+1 rulings) so the same shape of\n  // computation will drive a per-quad heat-map once we have per-face shading.\n  // No extra surface evaluations: we reuse railA/railB (3D) and A2/B2 (2D).\n  //\n  // Metric 1 — geometric non-planarity: perpendicular distance from corner\n  //   B[i] to the plane of (A[i], A[i+1], B[i+1]), normalised by mean edge\n  //   length. Equivalently 3·V_tet / area(A,Ap,Bp) / avgEdge, computed\n  //   directly from the scalar triple product. Exactly zero for any planar\n  //   quad — cone strips are planar trapezoids and report 0 regardless of\n  //   ruling count. Grows with intrinsic surface curvature.\n  // Metric 2 — pattern distortion: relative error in the \"free\" diagonal\n  //   A[i]–B[i+1] between 3D and the unfolded 2D. The split diagonal\n  //   A[i+1]–B[i] is preserved exactly by circleIntersect; this one is not\n  //   when the 3D quad is non-planar, so it directly measures how much the\n  //   flat pattern lies.\n  let twistMax = 0;\n  let twistSumSq = 0;\n  let distMax = 0;\n  let distSumSq = 0;\n  let worstStrip = 0;\n  let worstAbs = 0;\n  // Per-quad twist values, retained so the renderer can colour the unfolded\n  // pattern by developability quality.\n  const twistPerQuad: number[] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    const A = railA[i];\n    const Ap = railA[i + 1];\n    const B = railB[i];\n    const Bp = railB[i + 1];\n    // Edge vectors out of A.\n    const e1x = Ap[0] - A[0],\n      e1y = Ap[1] - A[1],\n      e1z = Ap[2] - A[2];\n    const e2x = Bp[0] - A[0],\n      e2y = Bp[1] - A[1],\n      e2z = Bp[2] - A[2];\n    const e3x = B[0] - A[0],\n      e3y = B[1] - A[1],\n      e3z = B[2] - A[2];\n    // n = e1 × e2 — normal of plane (A, Ap, Bp); |n| = 2 · area of triangle.\n    const nx = e1y * e2z - e1z * e2y;\n    const ny = e1z * e2x - e1x * e2z;\n    const nz = e1x * e2y - e1y * e2x;\n    const nMag = Math.hypot(nx, ny, nz);\n    // Perpendicular distance from B to that plane.\n    const height =\n      nMag > 0 ? Math.abs(nx * e3x + ny * e3y + nz * e3z) / nMag : 0;\n    const avgEdge =\n      0.25 * (dist3(A, Ap) + dist3(Ap, Bp) + dist3(Bp, B) + dist3(B, A));\n    const twist = avgEdge > 0 ? height / avgEdge : 0;\n    if (twist > twistMax) twistMax = twist;\n    twistSumSq += twist * twist;\n    twistPerQuad[i] = twist;\n\n    const d3 = dist3(A, Bp);\n    const d2 = Math.hypot(A2[i][0] - B2[i + 1][0], A2[i][1] - B2[i + 1][1]);\n    const absErr = Math.abs(d2 - d3);\n    const relErr = d3 > 0 ? absErr / d3 : 0;\n    distSumSq += relErr * relErr;\n    if (relErr > distMax) {\n      distMax = relErr;\n      worstStrip = i;\n      worstAbs = absErr;\n    }\n  }\n  const twistRMS = Math.sqrt(twistSumSq / n);\n  const distRMS = Math.sqrt(distSumSq / n);\n  const verdict =\n    twistMax < 1e-3\n      ? \"DEVELOPABLE\"\n      : twistMax < 1e-2\n        ? \"NEARLY DEVELOPABLE\"\n        : \"NON-DEVELOPABLE\";\n  console.log(\n    `Develop: ${n} strip${n === 1 ? \"\" : \"s\"}, axis=${axis}\\n` +\n    `  Developability:     max non-planarity ${twistMax.toExponential(2)} | ` +\n    `RMS ${twistRMS.toExponential(2)}  →  ${verdict}\\n` +\n    `  Pattern distortion: max ${(distMax * 100).toFixed(3)}% | ` +\n    `RMS ${(distRMS * 100).toFixed(3)}%  (worst at strip ${worstStrip}: ` +\n    `${worstAbs.toFixed(4)} length units)`,\n  );\n\n  // ── Step 6: Build the closed boundary polyline as a Drawing ──────────────\n  // Outline order: A2[0] → A2[1] → ... → A2[n] → B2[n] → ... → B2[0] → close.\n  const pen = replicad.draw(A2[0]);\n  for (let i = 1; i <= n; i++) pen.lineTo(A2[i]);\n  for (let i = n; i >= 0; i--) pen.lineTo(B2[i]);\n  let drawing = pen.close();\n\n  // ── Step 6b: Punch holes from inner wires (if any) ─────────────────────\n  // For each inner wire, sample it in 3D, map every sample to its 2D pattern\n  // position with the bilinear strip helper, then cut the resulting closed\n  // polyline out of the outer pattern. The mapping is exact at strip corners\n  // and on shared rulings, so a hole that crosses a ruling stays continuous\n  // across strips; inside a strip the error scales with the per-quad\n  // non-planarity reported above.\n  const innerWires = face.clone().innerWires();\n  if (innerWires && innerWires.length > 0) {\n    // Locate the strip [i, i+1] containing cross-axis value c. crossParamArr\n    // is monotonic crossMinActual+ε .. crossMaxActual−ε (n+1 entries).\n    const stripIndexFor = (c: number): number => {\n      let i = Math.floor(((c - crossMinActual) * n) / crossSpan);\n      if (i < 0) i = 0;\n      if (i > n - 1) i = n - 1;\n      return i;\n    };\n    const mapUVToPattern = (uvAbs: T2): T2 => {\n      const c = uvAbs[crossIdx];\n      const a = uvAbs[alongIdx];\n      const i = stripIndexFor(c);\n      const cLo = crossParamArr[i];\n      const cHi = crossParamArr[i + 1];\n      const sRaw = cHi === cLo ? 0 : (c - cLo) / (cHi - cLo);\n      const s = sRaw < 0 ? 0 : sRaw > 1 ? 1 : sRaw;\n      // Linearly blend the two rulings' clipped along-extents at this c.\n      const aLo = (1 - s) * alongLowArr[i] + s * alongLowArr[i + 1];\n      const aHi = (1 - s) * alongHighArr[i] + s * alongHighArr[i + 1];\n      const tRaw = aHi === aLo ? 0 : (a - aLo) / (aHi - aLo);\n      const t = tRaw < 0 ? 0 : tRaw > 1 ? 1 : tRaw;\n      // Bilinear over A2[i], A2[i+1], B2[i], B2[i+1].\n      // A2 corresponds to alongLow (t=0); B2 to alongHigh (t=1).\n      const topX = (1 - s) * A2[i][0] + s * A2[i + 1][0];\n      const topY = (1 - s) * A2[i][1] + s * A2[i + 1][1];\n      const botX = (1 - s) * B2[i][0] + s * B2[i + 1][0];\n      const botY = (1 - s) * B2[i][1] + s * B2[i + 1][1];\n      return [(1 - t) * topX + t * botX, (1 - t) * topY + t * botY];\n    };\n\n    for (let h = 0; h < innerWires.length; h++) {\n      const wire = innerWires[h];\n      const samples2D: T2[] = [];\n      for (let i = 0; i < holeN; i++) {\n        const t = i / holeN;\n        const p3d = wire.pointAt(t);\n        const uvAbs = face.uvCoordinates(p3d);\n        samples2D.push(mapUVToPattern([uvAbs[0], uvAbs[1]]));\n      }\n      if (samples2D.length < 3) continue;\n      const holePen = replicad.draw(samples2D[0]);\n      for (let i = 1; i < samples2D.length; i++) holePen.lineTo(samples2D[i]);\n      const holeDrawing = holePen.close();\n      drawing = drawing.cut(holeDrawing);\n    }\n  }\n\n  return new Assembly({\n    geometry: drawing,\n    color: \"#5B9BD5\",\n    tags: [\"developed\", \"ruling-axis:\" + axis],\n    metadata: {\n      heatmap: buildHeatmapPayload(A2, B2, twistPerQuad, n),\n    },\n  });\n}\n\n/**\n * Assemble the per-quad twist field into the generic `metadata.heatmap`\n * payload the renderer consumes. Quad corner order matches the Step-5 split:\n *   (A2[i], A2[i+1], B2[i+1], B2[i]).\n * `targetEdge` is a hint for downstream mesh subdivision: half the average\n * 2D quad edge length, so the colour mesh gets at least ~2 samples per quad\n * regardless of the underlying tessellation density.\n */\nfunction buildHeatmapPayload(\n  A2: Array<[number, number]>,\n  B2: Array<[number, number]>,\n  twistPerQuad: number[],\n  n: number,\n) {\n  const quads: Array<\n    [\n      [number, number],\n      [number, number],\n      [number, number],\n      [number, number],\n    ]\n  > = new Array(n);\n  let edgeSum = 0;\n  let edgeCount = 0;\n  for (let i = 0; i < n; i++) {\n    const a = A2[i];\n    const aNext = A2[i + 1];\n    const b = B2[i];\n    const bNext = B2[i + 1];\n    quads[i] = [a, aNext, bNext, b];\n    edgeSum +=\n      Math.hypot(aNext[0] - a[0], aNext[1] - a[1]) +\n      Math.hypot(bNext[0] - aNext[0], bNext[1] - aNext[1]) +\n      Math.hypot(b[0] - bNext[0], b[1] - bNext[1]) +\n      Math.hypot(a[0] - b[0], a[1] - b[1]);\n    edgeCount += 4;\n  }\n  const avgEdge2D = edgeCount > 0 ? edgeSum / edgeCount : 0;\n  return {\n    kind: \"perQuadField\",\n    quads,\n    values: twistPerQuad,\n    range: [0, 0.01] as [number, number],\n    gradient: [\"#ffffff\", \"#ff0000\"] as [string, string],\n    targetEdge: avgEdge2D > 0 ? avgEdge2D * 0.5 : undefined,\n  };\n}\n",
          "compiledCode": "\"use strict\";\n/**\n * Develops (flattens) a ruled surface into a 2D Drawing of its boundary.\n *\n * Input must be an Assembly containing a single replicad.Face — typically the\n * side face of a ruled loft. The atom samples `numRulings + 1` straight-line\n * generators across the surface (clipped to the face's trimmed outer wire),\n * then unfolds the resulting quad strip triangle-by-triangle into the plane\n * using rigid (length-preserving) edges. The returned Drawing is the closed\n * boundary of the flattened pattern, with any inner wires (holes) on the\n * source face punched out of the result.\n *\n *   rulingAxis === \"U\" / \"V\" / \"auto\" — same conventions as the rulings atom.\n *   seamAtStart === true → first ruling lies along +X in the 2D pattern;\n *                          rest of the pattern unfolds toward +Y.\n *   boundarySamples       → number of points used to approximate the trimmed\n *                          outer wire as a UV polyline. Increase if a curved\n *                          boundary (e.g. a small-radius arc) is being clipped\n *                          inaccurately; decrease for faster execution.\n *   holeSamples           → number of samples per inner wire (hole). Each hole\n *                          becomes a polygon with this many sides in the 2D\n *                          pattern; raise for smoother curves.\n *\n * If the surface is not developable at a particular strip (the four edge\n * lengths don't admit a planar quad) the atom throws an explicit error\n * naming the strip index.\n */\nfunction run(surface, numRulings = 24, rulingAxis = \"auto\", seamAtStart = true, boundarySamples = 256, holeSamples = 64) {\n    // ── Step 1: Validate input is a single Face ───────────────────────────────\n    if (!surface || !surface.isLeaf || !surface.isLeaf()) {\n        throw new Error(\"Develop surface: input must be an Assembly with exactly one leaf \" +\n            \"(the ruled surface as a replicad.Face).\");\n    }\n    const face = surface.geometry;\n    if (!(face instanceof replicad.Face)) {\n        throw new Error(\"Develop surface: input geometry must be a replicad.Face from a ruled \" +\n            \"loft; got \" +\n            (face && face.constructor ? face.constructor.name : typeof face));\n    }\n    if (!Number.isFinite(numRulings) || numRulings < 1) {\n        throw new Error(\"Develop surface: numRulings must be a positive integer.\");\n    }\n    if (!Number.isFinite(boundarySamples) || boundarySamples < 8) {\n        throw new Error(\"Develop surface: boundarySamples must be an integer ≥ 8 (used to \" +\n            \"approximate the trimmed outer wire as a UV polyline).\");\n    }\n    if (!Number.isFinite(holeSamples) || holeSamples < 8) {\n        throw new Error(\"Develop surface: holeSamples must be an integer ≥ 8 (used to \" +\n            \"approximate each inner wire as a polygon in the 2D pattern).\");\n    }\n    const n = Math.max(1, Math.floor(numRulings));\n    const boundaryN = Math.max(8, Math.floor(boundarySamples));\n    const holeN = Math.max(8, Math.floor(holeSamples));\n    const { uMin, uMax, vMin, vMax } = face.UVBounds;\n    // IMPORTANT: replicad's face.pointOnSurface(u, v) takes NORMALISED\n    // parameters in [0, 1] (internally it computes uMin + u*(uMax-uMin)), while\n    // face.UVBounds and face.uvCoordinates(...) return ABSOLUTE OCCT parameter\n    // values. We use absolute params everywhere outside this helper so the\n    // clipping math stays consistent with uvCoordinates() output, and convert\n    // to normalised here at the actual call to pointOnSurface.\n    const uSpan = uMax - uMin;\n    const vSpan = vMax - vMin;\n    const sampleTuple = (uAbs, vAbs) => {\n        const uN = uSpan === 0 ? 0 : (uAbs - uMin) / uSpan;\n        const vN = vSpan === 0 ? 0 : (vAbs - vMin) / vSpan;\n        const p = face.pointOnSurface(uN, vN);\n        return [p.x, p.y, p.z];\n    };\n    // ── Step 2: Auto-detect / validate the ruling axis ───────────────────────\n    // Same heuristic as the rulings atom: an iso-curve is \"straight\" when the\n    // midpoint sag is negligible relative to the chord length.\n    const STRAIGHT_TOL = 1e-4;\n    const isStraightAlong = (which) => {\n        const cross = which === \"U\" ? vMin + 0.5 * (vMax - vMin) : uMin + 0.5 * (uMax - uMin);\n        const a = which === \"U\" ? uMin : vMin;\n        const b = which === \"U\" ? uMax : vMax;\n        const get = (t) => which === \"U\" ? sampleTuple(t, cross) : sampleTuple(cross, t);\n        const p0 = get(a);\n        const pm = get(0.5 * (a + b));\n        const p1 = get(b);\n        const dx = p1[0] - p0[0], dy = p1[1] - p0[1], dz = p1[2] - p0[2];\n        const chord = Math.hypot(dx, dy, dz);\n        if (chord === 0)\n            return false;\n        const tx = pm[0] - p0[0], ty = pm[1] - p0[1], tz = pm[2] - p0[2];\n        const cx = dy * tz - dz * ty;\n        const cy = dz * tx - dx * tz;\n        const cz = dx * ty - dy * tx;\n        const perp = Math.hypot(cx, cy, cz) / chord;\n        return perp / chord < STRAIGHT_TOL;\n    };\n    let axis;\n    if (rulingAxis === \"U\" || rulingAxis === \"V\") {\n        axis = rulingAxis;\n    }\n    else if (rulingAxis === \"auto\") {\n        if (isStraightAlong(\"V\"))\n            axis = \"V\";\n        else if (isStraightAlong(\"U\"))\n            axis = \"U\";\n        else\n            throw new Error(\"Develop surface: auto-detect failed — surface is not straight along \" +\n                \"either parametric axis. Override with rulingAxis: 'U' or 'V'.\");\n    }\n    else {\n        throw new Error('Develop surface: rulingAxis must be \"auto\", \"U\", or \"V\"; got ' +\n            JSON.stringify(rulingAxis));\n    }\n    // ── Step 3: Sample the trimmed boundary in UV space ──────────────────────\n    // face.pointOnSurface() walks the underlying parametric surface, which can\n    // extend well beyond the actual trimmed face — e.g. a conical loft's\n    // underlying surface continues toward its apex below the bottom circle.\n    // We follow face.outerWire() in UV space and use it to clip each ruling to\n    // the trimmed region.\n    const outerWire = face.clone().outerWire();\n    const uvBoundary = [];\n    for (let i = 0; i < boundaryN; i++) {\n        const t = i / boundaryN;\n        const p3d = outerWire.pointAt(t);\n        const uv = face.uvCoordinates(p3d);\n        uvBoundary.push([uv[0], uv[1]]);\n    }\n    // Indices into a [u, v] tuple for the cross-axis (perpendicular to rulings)\n    // vs the along-axis (parallel to rulings).\n    //   axis === \"V\": rulings sweep V; cross-axis is U  → crossIdx=0, alongIdx=1\n    //   axis === \"U\": rulings sweep U; cross-axis is V  → crossIdx=1, alongIdx=0\n    const crossIdx = axis === \"V\" ? 0 : 1;\n    const alongIdx = 1 - crossIdx;\n    // Actual cross-axis extent of the trimmed boundary.\n    let crossMinActual = Infinity;\n    let crossMaxActual = -Infinity;\n    for (const uv of uvBoundary) {\n        if (uv[crossIdx] < crossMinActual)\n            crossMinActual = uv[crossIdx];\n        if (uv[crossIdx] > crossMaxActual)\n            crossMaxActual = uv[crossIdx];\n    }\n    const crossSpan = crossMaxActual - crossMinActual;\n    if (!(crossSpan > 0)) {\n        throw new Error(\"Develop surface: trimmed boundary has zero extent on the cross-axis.\");\n    }\n    // Intersect the iso-line \"cross-axis = crossParam\" with the closed UV\n    // polyline and return [alongMin, alongMax] — the actual along-axis extent\n    // of the trimmed face at that cross-axis value.\n    const rulingRange = (crossParam) => {\n        const hits = [];\n        const N = uvBoundary.length;\n        for (let j = 0; j < N; j++) {\n            const a = uvBoundary[j];\n            const b = uvBoundary[(j + 1) % N];\n            const aC = a[crossIdx];\n            const bC = b[crossIdx];\n            if (aC === bC)\n                continue;\n            // Skip seam wraparounds on periodic surfaces: a segment that jumps\n            // more than half the cross-axis span is almost certainly the U=0 ↔ U=2π\n            // discontinuity, not a real boundary edge.\n            if (Math.abs(bC - aC) > 0.5 * crossSpan)\n                continue;\n            // Half-open straddle so a vertex lying exactly on the iso-line is\n            // counted by exactly one of its two incident segments.\n            const straddles = (aC <= crossParam && bC > crossParam) ||\n                (bC <= crossParam && aC > crossParam);\n            if (!straddles)\n                continue;\n            const t = (crossParam - aC) / (bC - aC);\n            hits.push(a[alongIdx] + t * (b[alongIdx] - a[alongIdx]));\n        }\n        if (hits.length < 2) {\n            throw new Error(`Develop surface: cross-axis ${axis === \"V\" ? \"U\" : \"V\"}=` +\n                `${crossParam.toFixed(4)} intersects the outer wire at ` +\n                `${hits.length} point(s) (expected ≥2). The boundary may be ` +\n                `degenerate at this parameter, or boundarySamples may be too low ` +\n                `to resolve it.`);\n        }\n        hits.sort((a, b) => a - b);\n        return [hits[0], hits[hits.length - 1]];\n    };\n    // ── Step 4: Sample the two 3D rails using clipped iso-line ranges ────────\n    const railA = [];\n    const railB = [];\n    // Per-ruling absolute UV values, retained so the hole-mapping helper below\n    // can reconstruct the strip's clip range at any cross-axis parameter.\n    const crossParamArr = [];\n    const alongLowArr = [];\n    const alongHighArr = [];\n    for (let i = 0; i <= n; i++) {\n        const t = i / n;\n        let crossParam = crossMinActual + t * crossSpan;\n        // Nudge the very first and last samples a hair inward so the iso-line\n        // genuinely crosses the boundary polygon (it may be tangent at the\n        // extreme cross-axis values, giving <2 hits otherwise).\n        if (i === 0)\n            crossParam += crossSpan * 1e-6;\n        if (i === n)\n            crossParam -= crossSpan * 1e-6;\n        const [alongLow, alongHigh] = rulingRange(crossParam);\n        const aU = axis === \"V\" ? crossParam : alongLow;\n        const aV = axis === \"V\" ? alongLow : crossParam;\n        const bU = axis === \"V\" ? crossParam : alongHigh;\n        const bV = axis === \"V\" ? alongHigh : crossParam;\n        railA.push(sampleTuple(aU, aV));\n        railB.push(sampleTuple(bU, bV));\n        crossParamArr.push(crossParam);\n        alongLowArr.push(alongLow);\n        alongHighArr.push(alongHigh);\n    }\n    const dist3 = (p, q) => Math.hypot(p[0] - q[0], p[1] - q[1], p[2] - q[2]);\n    // ── Step 5: 2D unfold ─────────────────────────────────────────────────────\n    // Each quad has corners A[i], A[i+1], B[i+1], B[i]. We split it along the\n    // diagonal A[i+1]–B[i] into two triangles; rigid edge lengths in 3D become\n    // identical edge lengths in 2D. circleIntersect places the new vertex by\n    // intersecting two circles centred on already-placed vertices.\n    //\n    // sideSign = +1 places the result on the LEFT of the directed line p0→p1\n    //            (rotating (p1-p0) by +90° gives the +sideSign half-plane).\n    const CIRCLE_EPS = 1e-6;\n    const circleIntersect = (p0, r0, p1, r1, sideSign, stripIdx) => {\n        const dx = p1[0] - p0[0];\n        const dy = p1[1] - p0[1];\n        const d = Math.hypot(dx, dy);\n        const sum = r0 + r1;\n        const diff = Math.abs(r0 - r1);\n        if (d === 0 || d > sum * (1 + CIRCLE_EPS) || d < diff * (1 - CIRCLE_EPS)) {\n            throw new Error(`Develop surface: non-flattenable quad at strip ${stripIdx} ` +\n                `(circles r0=${r0.toFixed(4)}, r1=${r1.toFixed(4)}, ` +\n                `centre-distance=${d.toFixed(4)}). The ruled surface is not ` +\n                `developable here — try a different rulingAxis, or accept that ` +\n                `this loft cannot be flattened without distortion.`);\n        }\n        // Clamp for numerical stability when d is right at the boundary.\n        const dC = Math.max(diff, Math.min(sum, d));\n        const a = (r0 * r0 - r1 * r1 + dC * dC) / (2 * dC);\n        const h = Math.sqrt(Math.max(0, r0 * r0 - a * a));\n        const ux = dx / d;\n        const uy = dy / d;\n        const mx = p0[0] + a * ux;\n        const my = p0[1] + a * uy;\n        // Perpendicular (left-hand rotation by +90°) scaled by sideSign.\n        return [mx + h * -uy * sideSign, my + h * ux * sideSign];\n    };\n    const cross2 = (a, b) => a[0] * b[1] - a[1] * b[0];\n    const sub2 = (a, b) => [a[0] - b[0], a[1] - b[1]];\n    const A2 = new Array(n + 1);\n    const B2 = new Array(n + 1);\n    const lenR0 = dist3(railA[0], railB[0]);\n    A2[0] = [0, 0];\n    B2[0] = seamAtStart ? [lenR0, 0] : [0, lenR0];\n    for (let i = 0; i < n; i++) {\n        const lenAi = dist3(railA[i], railA[i + 1]);\n        const lenBi = dist3(railB[i], railB[i + 1]);\n        const lenRn = dist3(railA[i + 1], railB[i + 1]);\n        const diag = dist3(railA[i + 1], railB[i]);\n        // Place A2[i+1]: triangle (A2[i], B2[i], A2[i+1]) with sides lenR_i, diag, lenAi.\n        // For i=0 we pick the LEFT side (sideSign=+1) so the pattern unfolds toward\n        // the positive perpendicular of B2[0]→A2[0]. For i>=1 we pick the side\n        // OPPOSITE A2[i-1] so successive strips advance forward instead of folding.\n        let signA;\n        if (i === 0) {\n            signA = 1;\n        }\n        else {\n            const prev = Math.sign(cross2(sub2(B2[i], A2[i]), sub2(A2[i - 1], A2[i])));\n            signA = -prev || 1;\n        }\n        A2[i + 1] = circleIntersect(A2[i], lenAi, B2[i], diag, signA, i);\n        // Place B2[i+1]: triangle (A2[i+1], B2[i], B2[i+1]) with sides lenRn, lenBi, diag.\n        // Pick the side OPPOSITE A2[i] so the quad doesn't fold across its diagonal.\n        const sideOfAi = Math.sign(cross2(sub2(B2[i], A2[i + 1]), sub2(A2[i], A2[i + 1])));\n        const signB = -sideOfAi || 1;\n        B2[i + 1] = circleIntersect(A2[i + 1], lenRn, B2[i], lenBi, signB, i);\n    }\n    // ── Step 5b: Developability quality metrics ──────────────────────────────\n    // Both metrics are per-quad (n quads for n+1 rulings) so the same shape of\n    // computation will drive a per-quad heat-map once we have per-face shading.\n    // No extra surface evaluations: we reuse railA/railB (3D) and A2/B2 (2D).\n    //\n    // Metric 1 — geometric non-planarity: perpendicular distance from corner\n    //   B[i] to the plane of (A[i], A[i+1], B[i+1]), normalised by mean edge\n    //   length. Equivalently 3·V_tet / area(A,Ap,Bp) / avgEdge, computed\n    //   directly from the scalar triple product. Exactly zero for any planar\n    //   quad — cone strips are planar trapezoids and report 0 regardless of\n    //   ruling count. Grows with intrinsic surface curvature.\n    // Metric 2 — pattern distortion: relative error in the \"free\" diagonal\n    //   A[i]–B[i+1] between 3D and the unfolded 2D. The split diagonal\n    //   A[i+1]–B[i] is preserved exactly by circleIntersect; this one is not\n    //   when the 3D quad is non-planar, so it directly measures how much the\n    //   flat pattern lies.\n    let twistMax = 0;\n    let twistSumSq = 0;\n    let distMax = 0;\n    let distSumSq = 0;\n    let worstStrip = 0;\n    let worstAbs = 0;\n    // Per-quad twist values, retained so the renderer can colour the unfolded\n    // pattern by developability quality.\n    const twistPerQuad = new Array(n);\n    for (let i = 0; i < n; i++) {\n        const A = railA[i];\n        const Ap = railA[i + 1];\n        const B = railB[i];\n        const Bp = railB[i + 1];\n        // Edge vectors out of A.\n        const e1x = Ap[0] - A[0], e1y = Ap[1] - A[1], e1z = Ap[2] - A[2];\n        const e2x = Bp[0] - A[0], e2y = Bp[1] - A[1], e2z = Bp[2] - A[2];\n        const e3x = B[0] - A[0], e3y = B[1] - A[1], e3z = B[2] - A[2];\n        // n = e1 × e2 — normal of plane (A, Ap, Bp); |n| = 2 · area of triangle.\n        const nx = e1y * e2z - e1z * e2y;\n        const ny = e1z * e2x - e1x * e2z;\n        const nz = e1x * e2y - e1y * e2x;\n        const nMag = Math.hypot(nx, ny, nz);\n        // Perpendicular distance from B to that plane.\n        const height = nMag > 0 ? Math.abs(nx * e3x + ny * e3y + nz * e3z) / nMag : 0;\n        const avgEdge = 0.25 * (dist3(A, Ap) + dist3(Ap, Bp) + dist3(Bp, B) + dist3(B, A));\n        const twist = avgEdge > 0 ? height / avgEdge : 0;\n        if (twist > twistMax)\n            twistMax = twist;\n        twistSumSq += twist * twist;\n        twistPerQuad[i] = twist;\n        const d3 = dist3(A, Bp);\n        const d2 = Math.hypot(A2[i][0] - B2[i + 1][0], A2[i][1] - B2[i + 1][1]);\n        const absErr = Math.abs(d2 - d3);\n        const relErr = d3 > 0 ? absErr / d3 : 0;\n        distSumSq += relErr * relErr;\n        if (relErr > distMax) {\n            distMax = relErr;\n            worstStrip = i;\n            worstAbs = absErr;\n        }\n    }\n    const twistRMS = Math.sqrt(twistSumSq / n);\n    const distRMS = Math.sqrt(distSumSq / n);\n    const verdict = twistMax < 1e-3\n        ? \"DEVELOPABLE\"\n        : twistMax < 1e-2\n            ? \"NEARLY DEVELOPABLE\"\n            : \"NON-DEVELOPABLE\";\n    console.log(`Develop: ${n} strip${n === 1 ? \"\" : \"s\"}, axis=${axis}\\n` +\n        `  Developability:     max non-planarity ${twistMax.toExponential(2)} | ` +\n        `RMS ${twistRMS.toExponential(2)}  →  ${verdict}\\n` +\n        `  Pattern distortion: max ${(distMax * 100).toFixed(3)}% | ` +\n        `RMS ${(distRMS * 100).toFixed(3)}%  (worst at strip ${worstStrip}: ` +\n        `${worstAbs.toFixed(4)} length units)`);\n    // ── Step 6: Build the closed boundary polyline as a Drawing ──────────────\n    // Outline order: A2[0] → A2[1] → ... → A2[n] → B2[n] → ... → B2[0] → close.\n    const pen = replicad.draw(A2[0]);\n    for (let i = 1; i <= n; i++)\n        pen.lineTo(A2[i]);\n    for (let i = n; i >= 0; i--)\n        pen.lineTo(B2[i]);\n    let drawing = pen.close();\n    // ── Step 6b: Punch holes from inner wires (if any) ─────────────────────\n    // For each inner wire, sample it in 3D, map every sample to its 2D pattern\n    // position with the bilinear strip helper, then cut the resulting closed\n    // polyline out of the outer pattern. The mapping is exact at strip corners\n    // and on shared rulings, so a hole that crosses a ruling stays continuous\n    // across strips; inside a strip the error scales with the per-quad\n    // non-planarity reported above.\n    const innerWires = face.clone().innerWires();\n    if (innerWires && innerWires.length > 0) {\n        // Locate the strip [i, i+1] containing cross-axis value c. crossParamArr\n        // is monotonic crossMinActual+ε .. crossMaxActual−ε (n+1 entries).\n        const stripIndexFor = (c) => {\n            let i = Math.floor(((c - crossMinActual) * n) / crossSpan);\n            if (i < 0)\n                i = 0;\n            if (i > n - 1)\n                i = n - 1;\n            return i;\n        };\n        const mapUVToPattern = (uvAbs) => {\n            const c = uvAbs[crossIdx];\n            const a = uvAbs[alongIdx];\n            const i = stripIndexFor(c);\n            const cLo = crossParamArr[i];\n            const cHi = crossParamArr[i + 1];\n            const sRaw = cHi === cLo ? 0 : (c - cLo) / (cHi - cLo);\n            const s = sRaw < 0 ? 0 : sRaw > 1 ? 1 : sRaw;\n            // Linearly blend the two rulings' clipped along-extents at this c.\n            const aLo = (1 - s) * alongLowArr[i] + s * alongLowArr[i + 1];\n            const aHi = (1 - s) * alongHighArr[i] + s * alongHighArr[i + 1];\n            const tRaw = aHi === aLo ? 0 : (a - aLo) / (aHi - aLo);\n            const t = tRaw < 0 ? 0 : tRaw > 1 ? 1 : tRaw;\n            // Bilinear over A2[i], A2[i+1], B2[i], B2[i+1].\n            // A2 corresponds to alongLow (t=0); B2 to alongHigh (t=1).\n            const topX = (1 - s) * A2[i][0] + s * A2[i + 1][0];\n            const topY = (1 - s) * A2[i][1] + s * A2[i + 1][1];\n            const botX = (1 - s) * B2[i][0] + s * B2[i + 1][0];\n            const botY = (1 - s) * B2[i][1] + s * B2[i + 1][1];\n            return [(1 - t) * topX + t * botX, (1 - t) * topY + t * botY];\n        };\n        for (let h = 0; h < innerWires.length; h++) {\n            const wire = innerWires[h];\n            const samples2D = [];\n            for (let i = 0; i < holeN; i++) {\n                const t = i / holeN;\n                const p3d = wire.pointAt(t);\n                const uvAbs = face.uvCoordinates(p3d);\n                samples2D.push(mapUVToPattern([uvAbs[0], uvAbs[1]]));\n            }\n            if (samples2D.length < 3)\n                continue;\n            const holePen = replicad.draw(samples2D[0]);\n            for (let i = 1; i < samples2D.length; i++)\n                holePen.lineTo(samples2D[i]);\n            const holeDrawing = holePen.close();\n            drawing = drawing.cut(holeDrawing);\n        }\n    }\n    return new Assembly({\n        geometry: drawing,\n        color: \"#5B9BD5\",\n        tags: [\"developed\", \"ruling-axis:\" + axis],\n        metadata: {\n            heatmap: buildHeatmapPayload(A2, B2, twistPerQuad, n),\n        },\n    });\n}\n/**\n * Assemble the per-quad twist field into the generic `metadata.heatmap`\n * payload the renderer consumes. Quad corner order matches the Step-5 split:\n *   (A2[i], A2[i+1], B2[i+1], B2[i]).\n * `targetEdge` is a hint for downstream mesh subdivision: half the average\n * 2D quad edge length, so the colour mesh gets at least ~2 samples per quad\n * regardless of the underlying tessellation density.\n */\nfunction buildHeatmapPayload(A2, B2, twistPerQuad, n) {\n    const quads = new Array(n);\n    let edgeSum = 0;\n    let edgeCount = 0;\n    for (let i = 0; i < n; i++) {\n        const a = A2[i];\n        const aNext = A2[i + 1];\n        const b = B2[i];\n        const bNext = B2[i + 1];\n        quads[i] = [a, aNext, bNext, b];\n        edgeSum +=\n            Math.hypot(aNext[0] - a[0], aNext[1] - a[1]) +\n                Math.hypot(bNext[0] - aNext[0], bNext[1] - aNext[1]) +\n                Math.hypot(b[0] - bNext[0], b[1] - bNext[1]) +\n                Math.hypot(a[0] - b[0], a[1] - b[1]);\n        edgeCount += 4;\n    }\n    const avgEdge2D = edgeCount > 0 ? edgeSum / edgeCount : 0;\n    return {\n        kind: \"perQuadField\",\n        quads,\n        values: twistPerQuad,\n        range: [0, 0.01],\n        gradient: [\"#ffffff\", \"#ff0000\"],\n        targetEdge: avgEdge2D > 0 ? avgEdge2D * 0.5 : undefined,\n    };\n}\n"
        },
        {
          "atomType": "Input",
          "x": 0.025384615384615384,
          "y": 0.3384615384615385,
          "uniqueID": "id-24208",
          "name": "StartFromEdge"
        },
        {
          "atomType": "Code",
          "x": 0.4166666666666667,
          "y": 0.7470238095238095,
          "uniqueID": "id-24209",
          "ioValues": [
            {
              "name": "surface",
              "ioValue": "__GEOMETRY_INPUT__"
            },
            {
              "name": "numRulings",
              "ioValue": 24
            },
            {
              "name": "primaryEdgeIndex",
              "ioValue": 0
            },
            {
              "name": "holeSamples",
              "ioValue": 200
            }
          ],
          "interpreterVersion": 1,
          "code": "/**\n * Unrolls (flattens) a ruled surface into a 2D Drawing of its boundary,\n * using the same primary/secondary ruling extractor as the rulings atom\n * (see atomimpl.ts and Wang et al., JCISE 2021).\n *\n * Because the 2-neighbour shortest path advances exactly one of (i, j) per\n * step, every pair of consecutive rulings shares an endpoint. The strip\n * between them is therefore a TRIANGLE, which is intrinsically planar and\n * unrolls exactly — no quad-skew distortion. The first ruling is laid along\n * +X; each subsequent triangle hinges across the shared ruling and is\n * placed on the opposite side from the prior triangle's apex.\n *\n * The two long edges (primary chain and secondary chain) are emitted as\n * smooth splines through the placed vertices; the two short edges (first\n * and last rulings) are straight line segments. Splines play better with\n * downstream CAM than dense polylines.\n *\n *   primaryEdgeIndex → cyclic index into face.outerWire().edges. The two\n *                      neighbouring edges are excluded; remaining edges form\n *                      the secondary, identical to atomimpl.ts.\n */\nfunction run(\n  surface: Assembly,\n  numRulings: number = 24,\n  primaryEdgeIndex: number = 0,\n  holeSamples: number = 64,\n): Assembly {\n  const face = validateAndExtractFace(surface);\n  if (!Number.isFinite(numRulings) || numRulings < 2) {\n    throw new Error(\n      \"Unroll surface: numRulings must be an integer ≥ 2 (two rulings \" +\n      \"needed to define a strip).\",\n    );\n  }\n  if (!Number.isFinite(primaryEdgeIndex)) {\n    throw new Error(\"Unroll surface: primaryEdgeIndex must be an integer. was: \" + primaryEdgeIndex);\n  }\n  if (!Number.isFinite(holeSamples) || holeSamples < 8) {\n    throw new Error(\"Unroll surface: holeSamples must be an integer ≥ 8.\");\n  }\n  const n = Math.max(2, Math.floor(numRulings));\n  const holeN = Math.max(8, Math.floor(holeSamples));\n\n  const { primary, secondaryEdges, pIdx } = partitionOuterWire(\n    face,\n    primaryEdgeIndex,\n  );\n  const P3 = samplePrimary(primary, n);\n  const S3 = sampleSecondary(secondaryEdges, n);\n  const cost = buildCostGrid(face, P3, S3);\n  const { path, totalCost } = findOptimalRulingPath(cost, P3, S3);\n  console.log(\n    `Unroll: ${path.length} rulings, total cost=${totalCost.toExponential(2)}`,\n  );\n\n  // UV coordinates of every primary/secondary sample on the underlying\n  // surface. We map hole samples through UV (single-valued chart), not 3D,\n  // so triangle containment is an unambiguous 2D point-in-triangle test.\n  const PUV: (T2 | null)[] = P3.map((p) => uvAtSafe(face, p));\n  const SUV: (T2 | null)[] = S3.map((p) => uvAtSafe(face, p));\n\n  // ── Unfold triangles ────────────────────────────────────────────────────\n  // P2[i] / S2[j] hold the 2D position of primary sample i / secondary\n  // sample j once it's been placed. Each path step extends exactly one of\n  // these arrays by one new entry.\n  const P2: (T2 | undefined)[] = new Array(n);\n  const S2: (T2 | undefined)[] = new Array(n);\n  const [i0, j0] = path[0];\n  const L0 = dist3(P3[i0], S3[j0]);\n  if (!(L0 > 0)) {\n    throw new Error(\"Unroll: first ruling has zero length; cannot orient.\");\n  }\n  // First ruling along +X: primary endpoint at origin, secondary endpoint at +X.\n  P2[i0] = [0, 0];\n  S2[j0] = [L0, 0];\n\n  // Per-strip triangle records, populated alongside the unfold. Vertex order\n  // is (hinge-primary, hinge-secondary, apex); 2D and UV triples stay in\n  // sync so a UV barycentric coord transfers directly to the 2D pattern.\n  const tris2D: [T2, T2, T2][] = [];\n  const trisUV: ([T2, T2, T2] | null)[] = [];\n  const tris3D: [T3, T3, T3][] = [];\n\n  for (let k = 0; k < path.length - 1; k++) {\n    const [i, j] = path[k];\n    const [iN, jN] = path[k + 1];\n    const advancedP = iN > i;\n    const newP3 = advancedP ? P3[iN] : S3[jN];\n    const r0 = dist3(P3[i], newP3);\n    const r1 = dist3(S3[j], newP3);\n    const p0 = P2[i]!;\n    const p1 = S2[j]!;\n\n    // Side choice: place the new apex on the opposite side of the current\n    // hinge (P2[i] → S2[j]) from the previous triangle's apex. For the\n    // first triangle there's no prior apex, so pick +1 (left of p0→p1)\n    // arbitrarily — the whole pattern just unfolds toward +Y.\n    let side: number;\n    if (k === 0) {\n      side = 1;\n    } else {\n      const [iPrev, jPrev] = path[k - 1];\n      // The previous triangle's apex is whichever of (P2[iPrev], S2[jPrev])\n      // is NOT shared with the current hinge. Exactly one of iPrev, jPrev\n      // differs from (i, j) — that one is the apex.\n      const otherPt: T2 = iPrev !== i ? P2[iPrev]! : S2[jPrev]!;\n      const ox = otherPt[0] - p0[0];\n      const oy = otherPt[1] - p0[1];\n      const hx = p1[0] - p0[0];\n      const hy = p1[1] - p0[1];\n      const sideOfOther = Math.sign(hx * oy - hy * ox);\n      side = -sideOfOther || 1;\n    }\n\n    const newP2 = circleIntersect(p0, r0, p1, r1, side, k);\n    if (advancedP) P2[iN] = newP2;\n    else S2[jN] = newP2;\n\n    tris2D.push([p0, p1, newP2]);\n    tris3D.push([P3[i], S3[j], newP3]);\n\n    const uvA = PUV[i];\n    const uvB = SUV[j];\n    const uvC = advancedP ? PUV[iN] : SUV[jN];\n    trisUV.push(uvA && uvB && uvC ? [uvA, uvB, uvC] : null);\n  }\n\n  // ── Build the two long chains in path order ────────────────────────────\n  // primaryChain = the 2D positions of the primary samples actually visited,\n  // in the order they appear along the path. Same for secondaryChain.\n  const primaryChain: T2[] = [];\n  const secondaryChain: T2[] = [];\n  let lastI = -1;\n  let lastJ = -1;\n  for (const [i, j] of path) {\n    if (i !== lastI) {\n      primaryChain.push(P2[i]!);\n      lastI = i;\n    }\n    if (j !== lastJ) {\n      secondaryChain.push(S2[j]!);\n      lastJ = j;\n    }\n  }\n  if (primaryChain.length < 2 || secondaryChain.length < 2) {\n    throw new Error(\n      `Unroll: degenerate chains (primary=${primaryChain.length}, ` +\n      `secondary=${secondaryChain.length}); need ≥2 on each side.`,\n    );\n  }\n\n  // ── Build the boundary drawing ─────────────────────────────────────────\n  // Primary chain (spline) → last ruling (straight) → reversed secondary\n  // chain (spline) → close back along first ruling (straight).\n  const pen = replicad.draw(primaryChain[0]);\n  for (let i = 1; i < primaryChain.length; i++) {\n    pen.lineTo(primaryChain[i]);\n  }\n  pen.lineTo(secondaryChain[secondaryChain.length - 1]);\n  for (let i = secondaryChain.length - 2; i >= 0; i--) {\n    pen.lineTo(secondaryChain[i]);\n  }\n  let drawing = pen.close();\n\n  // ── Punch holes from inner wires (if any) ───────────────────────\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const innerWires: any[] = face.clone().innerWires() ?? [];\n  for (let h = 0; h < innerWires.length; h++) {\n    const wire = innerWires[h];\n    // Pass 1: dense 3D samples around the wire.\n    const samples3D: T3[] = [];\n    for (let i = 0; i < holeN; i++) {\n      const t = i / holeN;\n      samples3D.push(toT3(wire.pointAt(t)));\n    }\n    if (samples3D.length < 3) continue;\n\n    // Pass 2: map 3D→2D using nearest physical triangle.\n    const samples2D: T2[] = samples3D\n      .map((p) => {\n        const k = findBestTriangle3D(p, tris3D);\n        return k >= 0 ? mapWithTriangle3D(p, k, tris3D, tris2D) : null;\n      })\n      .filter((p): p is T2 => p !== null);\n\n    if (samples2D.length < 3) continue;\n\n    // Pass 3: Draw the hole.\n    const holePen = replicad.draw(samples2D[0]);\n    for (let i = 1; i < samples2D.length; i++) {\n      holePen.lineTo(samples2D[i]);\n    }\n    const holeDrawing = holePen.close();\n    drawing = drawing.cut(holeDrawing);\n  }\n\n  return new Assembly({\n    geometry: drawing,\n    color: \"#5B9BD5\",\n    tags: [\"developed\", \"ruling-primary:\" + pIdx],\n  });\n}\n\n// ─── Shared helpers (mirror atomimpl.ts; sandboxed files can't import) ───\n\ntype T3 = [number, number, number];\ntype T2 = [number, number];\n\nfunction toT3(v: { x: number; y: number; z: number }): T3 {\n  return [v.x, v.y, v.z];\n}\n\nfunction dist3(a: T3, b: T3): number {\n  return Math.hypot(a[0] - b[0], a[1] - b[1], a[2] - b[2]);\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction validateAndExtractFace(surface: Assembly): any {\n  if (!surface || !surface.isLeaf || !surface.isLeaf()) {\n    throw new Error(\n      \"Unroll surface: input must be an Assembly with exactly one leaf \" +\n      \"(the ruled surface as a replicad.Face).\",\n    );\n  }\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const face = (surface as any).geometry;\n  if (!(face instanceof replicad.Face)) {\n    throw new Error(\n      \"Unroll surface: input geometry must be a replicad.Face; got \" +\n      (face && face.constructor ? face.constructor.name : typeof face),\n    );\n  }\n  return face;\n}\n\nfunction partitionOuterWire(\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  face: any,\n  primaryEdgeIndex: number,\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n): { primary: any; secondaryEdges: any[]; pIdx: number } {\n  const outerWire = face.clone().outerWire();\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const allEdges: any[] = outerWire.edges ?? [];\n  const m = allEdges.length;\n  const pIdx = ((Math.floor(primaryEdgeIndex) % m) + m) % m;\n  const primary = allEdges[pIdx];\n\n  const excludedIdx = new Set([pIdx]);\n  if (primary.isClosed) {\n    if (pIdx == 0) {\n      excludedIdx.add(1);\n    } else if (pIdx == allEdges.length - 1) {\n      excludedIdx.add(allEdges.length - 2);\n    } else {\n      console.warn(\"found a closed face with two neighbors..\");\n    }\n  } else {\n    excludedIdx.add((pIdx - 1 + m) % m);\n    excludedIdx.add((pIdx + 1) % m);\n  }\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const secondaryEdges: any[] = [];\n  for (let k = 0; k < m; k++) {\n    const idx = (pIdx + 2 + k) % m;\n    if (!excludedIdx.has(idx)) secondaryEdges.push(allEdges[idx]);\n  }\n  if (secondaryEdges.length === 0) {\n    throw new Error(\n      \"Unroll surface: no secondary edges remain after excluding primary \" +\n      \"and its two neighbours.\",\n    );\n  }\n  return { primary, secondaryEdges, pIdx };\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction samplePrimary(primary: any, n: number): T3[] {\n  const out: T3[] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    const t = n === 1 ? 0 : i / (n - 1);\n    out[i] = toT3(primary.pointAt(t));\n  }\n  return out;\n}\n\nfunction sampleSecondary(\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  secondaryEdges: any[],\n  n: number,\n): T3[] {\n  const secLengths = secondaryEdges.map((e) => e.length);\n  const secTotal = secLengths.reduce((a, b) => a + b, 0);\n  if (!(secTotal > 0)) {\n    throw new Error(\"Unroll surface: secondary edges have zero total length.\");\n  }\n  const perEdge: number[] = secondaryEdges.map((_, k) =>\n    Math.max(1, Math.round((n * secLengths[k]) / secTotal)),\n  );\n  let perSum = perEdge.reduce((a, b) => a + b, 0);\n  while (perSum !== n) {\n    let bestK = 0;\n    let bestLen = -1;\n    for (let k = 0; k < secondaryEdges.length; k++) {\n      if (secLengths[k] > bestLen) {\n        bestLen = secLengths[k];\n        bestK = k;\n      }\n    }\n    if (perSum < n) {\n      perEdge[bestK] += 1;\n      perSum += 1;\n    } else if (perEdge[bestK] > 1) {\n      perEdge[bestK] -= 1;\n      perSum -= 1;\n    } else {\n      break;\n    }\n  }\n  const samples: T3[] = [];\n  for (let k = 0; k < secondaryEdges.length; k++) {\n    const e = secondaryEdges[k];\n    const cnt = perEdge[k];\n    for (let i = 0; i < cnt; i++) {\n      const t = (i + 0.5) / cnt;\n      samples.push(toT3(e.pointAt(t)));\n    }\n  }\n  let cursor = 0;\n  for (let k = 0; k < secondaryEdges.length - 1; k++) {\n    cursor += perEdge[k];\n    const sharedVertex = toT3(secondaryEdges[k].endPoint);\n    const a = cursor - 1;\n    const b = cursor;\n    if (a < 0 || b >= samples.length) continue;\n    const dA = dist3(samples[a], sharedVertex);\n    const dB = dist3(samples[b], sharedVertex);\n    if (dA <= dB) samples[a] = sharedVertex;\n    else samples[b] = sharedVertex;\n  }\n  return samples;\n}\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction normalAtSafe(face: any, p: T3): T3 | null {\n  try {\n    const nv = face.normalAt(p);\n    const x = nv.x,\n      y = nv.y,\n      z = nv.z;\n    const len = Math.hypot(x, y, z);\n    if (!(len > 0)) return null;\n    return [x / len, y / len, z / len];\n  } catch {\n    return null;\n  }\n}\n\nfunction buildCostGrid(\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  face: any,\n  primarySamples: T3[],\n  secondarySamples: T3[],\n): number[][] {\n  const n = primarySamples.length;\n  const ns = secondarySamples.length;\n  const primaryNormals = primarySamples.map((p) => normalAtSafe(face, p));\n  const secondaryNormals = secondarySamples.map((p) => normalAtSafe(face, p));\n  const cost: number[][] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    const row: number[] = new Array(ns);\n    const nA = primaryNormals[i];\n    for (let j = 0; j < ns; j++) {\n      const nB = secondaryNormals[j];\n      if (!nA || !nB) {\n        row[j] = Infinity;\n        continue;\n      }\n      const dot = nA[0] * nB[0] + nA[1] * nB[1] + nA[2] * nB[2];\n      row[j] = 1 - Math.abs(dot);\n    }\n    cost[i] = row;\n  }\n  return cost;\n}\n\nfunction quadTwist(\n  P: T3[],\n  S: T3[],\n  i: number,\n  j: number,\n  iN: number,\n  jN: number,\n): number {\n  const A = P[i];\n  const Ap = P[iN];\n  const B = S[j];\n  const Bp = S[jN];\n  const e1x = Ap[0] - A[0],\n    e1y = Ap[1] - A[1],\n    e1z = Ap[2] - A[2];\n  const e2x = Bp[0] - A[0],\n    e2y = Bp[1] - A[1],\n    e2z = Bp[2] - A[2];\n  const e3x = B[0] - A[0],\n    e3y = B[1] - A[1],\n    e3z = B[2] - A[2];\n  const nx = e1y * e2z - e1z * e2y;\n  const ny = e1z * e2x - e1x * e2z;\n  const nz = e1x * e2y - e1y * e2x;\n  const nMag = Math.hypot(nx, ny, nz);\n  const height = nMag > 0 ? Math.abs(nx * e3x + ny * e3y + nz * e3z) / nMag : 0;\n  const avgEdge =\n    0.25 * (dist3(A, Ap) + dist3(Ap, Bp) + dist3(Bp, B) + dist3(B, A));\n  return avgEdge > 0 ? height / avgEdge : 0;\n}\n\n/**\n * 2-neighbour anti-diagonal DP: from (i, j) you may only advance to\n * (i+1, j) or (i, j+1). Every path has 2(n-1) steps and emits 2n-1 rulings.\n * Identical to the implementation in atomimpl.ts.\n */\nfunction findOptimalRulingPath(\n  cost: number[][],\n  P: T3[],\n  S: T3[],\n): { path: [number, number][]; totalCost: number } {\n  const n = cost.length;\n  const INF = Number.POSITIVE_INFINITY;\n  const dist: number[][] = new Array(n);\n  const prevDir: number[][] = new Array(n);\n  for (let i = 0; i < n; i++) {\n    dist[i] = new Array(n).fill(INF);\n    prevDir[i] = new Array(n).fill(-1);\n  }\n  dist[0][0] = cost[0][0];\n\n  for (let s = 1; s <= 2 * (n - 1); s++) {\n    const iLo = Math.max(0, s - (n - 1));\n    const iHi = Math.min(n - 1, s);\n    for (let iN = iLo; iN <= iHi; iN++) {\n      const jN = s - iN;\n      const rulingCost = cost[iN][jN];\n      if (!isFinite(rulingCost)) continue;\n      let best = INF;\n      let bestDir = -1;\n      if (iN > 0 && isFinite(dist[iN - 1][jN])) {\n        const cand =\n          dist[iN - 1][jN] + rulingCost + quadTwist(P, S, iN - 1, jN, iN, jN);\n        if (cand < best) {\n          best = cand;\n          bestDir = 0;\n        }\n      }\n      if (jN > 0 && isFinite(dist[iN][jN - 1])) {\n        const cand =\n          dist[iN][jN - 1] + rulingCost + quadTwist(P, S, iN, jN - 1, iN, jN);\n        if (cand < best) {\n          best = cand;\n          bestDir = 1;\n        }\n      }\n      if (best < INF) {\n        dist[iN][jN] = best;\n        prevDir[iN][jN] = bestDir;\n      }\n    }\n  }\n\n  const path: [number, number][] = [];\n  if (isFinite(dist[n - 1][n - 1])) {\n    let ci = n - 1;\n    let cj = n - 1;\n    while (ci >= 0 && cj >= 0) {\n      path.push([ci, cj]);\n      if (ci === 0 && cj === 0) break;\n      const dir = prevDir[ci][cj];\n      if (dir === 0) ci -= 1;\n      else if (dir === 1) cj -= 1;\n      else break;\n    }\n    path.reverse();\n    return { path, totalCost: dist[n - 1][n - 1] };\n  }\n  console.warn(\"Unroll: DAG search found no path; falling back to diagonal.\");\n  for (let k = 0; k < n; k++) path.push([k, k]);\n  return { path, totalCost: INF };\n}\n\n/**\n * Locate the unfold triangle whose plane is closest to `p`, returning the\n * 2D image of `p` under that triangle's affine 3D→2D map. We prefer\n * triangles where the projected point's barycentric coordinates are all\n * within [−ε, 1+ε] (i.e. inside the triangle); among those, pick the one\n * with the smallest perpendicular distance. If none qualify, fall back to\n * the globally closest triangle and clamp.\n */\n/**\n * Safely fetch the UV coordinates of a 3D point on `face`. Returns null if\n * the point is off-surface or OCCT raises (e.g. periodic-seam glitch).\n * `face.uvCoordinates(p)` may return either a `[u, v]` tuple or an\n * object with .u/.v depending on the replicad build; normalise both.\n */\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction uvAtSafe(face: any, p: T3): T2 | null {\n  try {\n    const r = face.uvCoordinates([p[0], p[1], p[2]]);\n    if (Array.isArray(r)) {\n      if (!isFinite(r[0]) || !isFinite(r[1])) return null;\n      return [r[0], r[1]];\n    }\n    if (r && typeof r.u === \"number\" && typeof r.v === \"number\") {\n      return [r.u, r.v];\n    }\n    return null;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Return the index of the unfold triangle whose UV image contains `uv`,\n * or -1 if none does. UV is a single-valued chart on the trimmed face, so\n * at most one triangle truly contains `uv`; a small ε accepts on-edge\n * points and either side resolves to the same 2D position (the affine\n * maps agree on the shared edge).\n */\nfunction findContainingTriangle(\n  uv: T2,\n  trisUV: ([T2, T2, T2] | null)[],\n): number {\n  const EPS = 1e-9;\n  for (let k = 0; k < trisUV.length; k++) {\n    const tri = trisUV[k];\n    if (!tri) continue;\n    const bary = baryUV(uv, tri[0], tri[1], tri[2]);\n    if (!bary) continue;\n    const [u, v, w] = bary;\n    if (u >= -EPS && v >= -EPS && w >= -EPS) return k;\n  }\n  return -1;\n}\n\n/**\n * Identify the best 3D triangle for a point P. We prefer the one where P\n * projects inside (positive barycentric), using physical distance to the\n * triangle plane as a tie-breaker.\n */\nfunction findBestTriangle3D(p: T3, tris3D: [T3, T3, T3][]): number {\n  let bestK = -1;\n  let minScore = Infinity;\n\n  for (let k = 0; k < tris3D.length; k++) {\n    const tri = tris3D[k];\n    const bary = bary3D(p, tri[0], tri[1], tri[2]);\n    if (!bary) continue;\n\n    const [u, v, w] = bary;\n    // Penalty for being physically outside the triangle footprint\n    const outsideDist = Math.max(0, -u, -v, -w);\n    // Distance to triangle plane\n    const planeDist = distToPlane(p, tri[0], tri[1], tri[2]);\n\n    // Combined score: proximity to plane + penalty for being outside.\n    // Being outside is penalized much more heavily than being slightly\n    // off-plane.\n    const score = planeDist + outsideDist * 1000;\n\n    if (score < minScore) {\n      minScore = score;\n      bestK = k;\n    }\n  }\n  return bestK;\n}\n\n/**\n * Project 3D point p into triangle k and return its 2D coordinates.\n */\nfunction mapWithTriangle3D(\n  p: T3,\n  k: number,\n  tris3D: [T3, T3, T3][],\n  tris2D: [T2, T2, T2][],\n): T2 {\n  const tri3 = tris3D[k];\n  const tri2 = tris2D[k];\n  const bary = bary3D(p, tri3[0], tri3[1], tri3[2]);\n  if (!bary) return [0, 0];\n\n  const [u, v, w] = bary;\n  const [a2, b2, c2] = tri2;\n\n  return [u * a2[0] + v * b2[0] + w * c2[0], u * a2[1] + v * b2[1] + w * c2[1]];\n}\n\nfunction distToPlane(p: T3, a: T3, b: T3, c: T3): number {\n  const v1 = [b[0] - a[0], b[1] - a[1], b[2] - a[2]];\n  const v2 = [c[0] - a[0], c[1] - a[1], c[2] - a[2]];\n\n  const nx = v1[1] * v2[2] - v1[2] * v2[1];\n  const ny = v1[2] * v2[0] - v1[0] * v2[2];\n  const nz = v1[0] * v2[1] - v1[1] * v2[0];\n  const nLen = Math.hypot(nx, ny, nz);\n  if (nLen === 0) return dist3(p, a);\n\n  const dx = p[0] - a[0];\n  const dy = p[1] - a[1];\n  const dz = p[2] - a[2];\n\n  return Math.abs(dx * nx + dy * ny + dz * nz) / nLen;\n}\n\n/**\n * 3D Barycentric coordinates of P in triangle (A, B, C).\n * P is projected onto the plane of ABC.\n */\nfunction bary3D(p: T3, a: T3, b: T3, c: T3): [number, number, number] | null {\n  const v0 = [b[0] - a[0], b[1] - a[1], b[2] - a[2]];\n  const v1 = [c[0] - a[0], c[1] - a[1], c[2] - a[2]];\n  const v2 = [p[0] - a[0], p[1] - a[1], p[2] - a[2]];\n\n  const d00 = v0[0] * v0[0] + v0[1] * v0[1] + v0[2] * v0[2];\n  const d01 = v0[0] * v1[0] + v0[1] * v1[1] + v0[2] * v1[2];\n  const d11 = v1[0] * v1[0] + v1[1] * v1[1] + v1[2] * v1[2];\n  const d20 = v2[0] * v0[0] + v2[1] * v0[1] + v2[2] * v0[2];\n  const d21 = v2[0] * v1[0] + v2[1] * v1[1] + v2[2] * v1[2];\n\n  const denom = d00 * d11 - d01 * d01;\n  if (Math.abs(denom) < 1e-12) return null;\n\n  const invDenom = 1.0 / denom;\n  const v = (d11 * d20 - d01 * d21) * invDenom;\n  const w = (d00 * d21 - d01 * d20) * invDenom;\n  const u = 1.0 - v - w;\n\n  return [u, v, w];\n}\n\n/**\n * Affine UV→2D map via the barycentric of `uv` in triangle `k`. Caller is\n * responsible for picking a triangle that (nearly) contains `uv`.\n */\nfunction mapWithTriangle(\n  uv: T2,\n  k: number,\n  trisUV: ([T2, T2, T2] | null)[],\n  tris2D: [T2, T2, T2][],\n): T2 {\n  const tri = trisUV[k];\n  if (!tri) return [0, 0];\n  const bary = baryUV(uv, tri[0], tri[1], tri[2]);\n  const [u, v, w] = bary ?? [1, 0, 0];\n  const [a2, b2, c2] = tris2D[k];\n  return [u * a2[0] + v * b2[0] + w * c2[0], u * a2[1] + v * b2[1] + w * c2[1]];\n}\n\n/** Signed-area barycentric of `p` in triangle (A, B, C) in 2D. Returns\n *  [u, v, w] with u+v+w=1; null on a zero-area triangle. */\nfunction baryUV(p: T2, A: T2, B: T2, C: T2): [number, number, number] | null {\n  const ax = B[0] - A[0],\n    ay = B[1] - A[1];\n  const bx = C[0] - A[0],\n    by = C[1] - A[1];\n  const denom = ax * by - ay * bx;\n  if (!(Math.abs(denom) > 0)) return null;\n  const px = p[0] - A[0],\n    py = p[1] - A[1];\n  const v = (px * by - py * bx) / denom;\n  const w = (ax * py - ay * px) / denom;\n  const u = 1 - v - w;\n  return [u, v, w];\n}\n\n/** Place a new 2D point at distance r0 from p0 and r1 from p1, on the\n * sideSign side of the directed line p0→p1 (+1 = left, −1 = right). */\nfunction circleIntersect(\n  p0: T2,\n  r0: number,\n  p1: T2,\n  r1: number,\n  sideSign: number,\n  stripIdx: number,\n): T2 {\n  const dx = p1[0] - p0[0];\n  const dy = p1[1] - p0[1];\n  const d = Math.hypot(dx, dy);\n  const sum = r0 + r1;\n  const diff = Math.abs(r0 - r1);\n  const EPS = 1e-6;\n  if (d === 0 || d > sum * (1 + EPS) || d < diff * (1 - EPS)) {\n    throw new Error(\n      `Unroll: degenerate triangle at strip ${stripIdx} ` +\n      `(r0=${r0.toFixed(4)}, r1=${r1.toFixed(4)}, hinge=${d.toFixed(4)}).`,\n    );\n  }\n  const dC = Math.max(diff, Math.min(sum, d));\n  const a = (r0 * r0 - r1 * r1 + dC * dC) / (2 * dC);\n  const h = Math.sqrt(Math.max(0, r0 * r0 - a * a));\n  const ux = dx / d;\n  const uy = dy / d;\n  const mx = p0[0] + a * ux;\n  const my = p0[1] + a * uy;\n  return [mx + h * -uy * sideSign, my + h * ux * sideSign];\n}\n",
          "compiledCode": "\"use strict\";\n/**\n * Unrolls (flattens) a ruled surface into a 2D Drawing of its boundary,\n * using the same primary/secondary ruling extractor as the rulings atom\n * (see atomimpl.ts and Wang et al., JCISE 2021).\n *\n * Because the 2-neighbour shortest path advances exactly one of (i, j) per\n * step, every pair of consecutive rulings shares an endpoint. The strip\n * between them is therefore a TRIANGLE, which is intrinsically planar and\n * unrolls exactly — no quad-skew distortion. The first ruling is laid along\n * +X; each subsequent triangle hinges across the shared ruling and is\n * placed on the opposite side from the prior triangle's apex.\n *\n * The two long edges (primary chain and secondary chain) are emitted as\n * smooth splines through the placed vertices; the two short edges (first\n * and last rulings) are straight line segments. Splines play better with\n * downstream CAM than dense polylines.\n *\n *   primaryEdgeIndex → cyclic index into face.outerWire().edges. The two\n *                      neighbouring edges are excluded; remaining edges form\n *                      the secondary, identical to atomimpl.ts.\n */\nfunction run(surface, numRulings = 24, primaryEdgeIndex = 0, holeSamples = 64) {\n    const face = validateAndExtractFace(surface);\n    if (!Number.isFinite(numRulings) || numRulings < 2) {\n        throw new Error(\"Unroll surface: numRulings must be an integer ≥ 2 (two rulings \" +\n            \"needed to define a strip).\");\n    }\n    if (!Number.isFinite(primaryEdgeIndex)) {\n        throw new Error(\"Unroll surface: primaryEdgeIndex must be an integer. was: \" + primaryEdgeIndex);\n    }\n    if (!Number.isFinite(holeSamples) || holeSamples < 8) {\n        throw new Error(\"Unroll surface: holeSamples must be an integer ≥ 8.\");\n    }\n    const n = Math.max(2, Math.floor(numRulings));\n    const holeN = Math.max(8, Math.floor(holeSamples));\n    const { primary, secondaryEdges, pIdx } = partitionOuterWire(face, primaryEdgeIndex);\n    const P3 = samplePrimary(primary, n);\n    const S3 = sampleSecondary(secondaryEdges, n);\n    const cost = buildCostGrid(face, P3, S3);\n    const { path, totalCost } = findOptimalRulingPath(cost, P3, S3);\n    console.log(`Unroll: ${path.length} rulings, total cost=${totalCost.toExponential(2)}`);\n    // UV coordinates of every primary/secondary sample on the underlying\n    // surface. We map hole samples through UV (single-valued chart), not 3D,\n    // so triangle containment is an unambiguous 2D point-in-triangle test.\n    const PUV = P3.map((p) => uvAtSafe(face, p));\n    const SUV = S3.map((p) => uvAtSafe(face, p));\n    // ── Unfold triangles ────────────────────────────────────────────────────\n    // P2[i] / S2[j] hold the 2D position of primary sample i / secondary\n    // sample j once it's been placed. Each path step extends exactly one of\n    // these arrays by one new entry.\n    const P2 = new Array(n);\n    const S2 = new Array(n);\n    const [i0, j0] = path[0];\n    const L0 = dist3(P3[i0], S3[j0]);\n    if (!(L0 > 0)) {\n        throw new Error(\"Unroll: first ruling has zero length; cannot orient.\");\n    }\n    // First ruling along +X: primary endpoint at origin, secondary endpoint at +X.\n    P2[i0] = [0, 0];\n    S2[j0] = [L0, 0];\n    // Per-strip triangle records, populated alongside the unfold. Vertex order\n    // is (hinge-primary, hinge-secondary, apex); 2D and UV triples stay in\n    // sync so a UV barycentric coord transfers directly to the 2D pattern.\n    const tris2D = [];\n    const trisUV = [];\n    const tris3D = [];\n    for (let k = 0; k < path.length - 1; k++) {\n        const [i, j] = path[k];\n        const [iN, jN] = path[k + 1];\n        const advancedP = iN > i;\n        const newP3 = advancedP ? P3[iN] : S3[jN];\n        const r0 = dist3(P3[i], newP3);\n        const r1 = dist3(S3[j], newP3);\n        const p0 = P2[i];\n        const p1 = S2[j];\n        // Side choice: place the new apex on the opposite side of the current\n        // hinge (P2[i] → S2[j]) from the previous triangle's apex. For the\n        // first triangle there's no prior apex, so pick +1 (left of p0→p1)\n        // arbitrarily — the whole pattern just unfolds toward +Y.\n        let side;\n        if (k === 0) {\n            side = 1;\n        }\n        else {\n            const [iPrev, jPrev] = path[k - 1];\n            // The previous triangle's apex is whichever of (P2[iPrev], S2[jPrev])\n            // is NOT shared with the current hinge. Exactly one of iPrev, jPrev\n            // differs from (i, j) — that one is the apex.\n            const otherPt = iPrev !== i ? P2[iPrev] : S2[jPrev];\n            const ox = otherPt[0] - p0[0];\n            const oy = otherPt[1] - p0[1];\n            const hx = p1[0] - p0[0];\n            const hy = p1[1] - p0[1];\n            const sideOfOther = Math.sign(hx * oy - hy * ox);\n            side = -sideOfOther || 1;\n        }\n        const newP2 = circleIntersect(p0, r0, p1, r1, side, k);\n        if (advancedP)\n            P2[iN] = newP2;\n        else\n            S2[jN] = newP2;\n        tris2D.push([p0, p1, newP2]);\n        tris3D.push([P3[i], S3[j], newP3]);\n        const uvA = PUV[i];\n        const uvB = SUV[j];\n        const uvC = advancedP ? PUV[iN] : SUV[jN];\n        trisUV.push(uvA && uvB && uvC ? [uvA, uvB, uvC] : null);\n    }\n    // ── Build the two long chains in path order ────────────────────────────\n    // primaryChain = the 2D positions of the primary samples actually visited,\n    // in the order they appear along the path. Same for secondaryChain.\n    const primaryChain = [];\n    const secondaryChain = [];\n    let lastI = -1;\n    let lastJ = -1;\n    for (const [i, j] of path) {\n        if (i !== lastI) {\n            primaryChain.push(P2[i]);\n            lastI = i;\n        }\n        if (j !== lastJ) {\n            secondaryChain.push(S2[j]);\n            lastJ = j;\n        }\n    }\n    if (primaryChain.length < 2 || secondaryChain.length < 2) {\n        throw new Error(`Unroll: degenerate chains (primary=${primaryChain.length}, ` +\n            `secondary=${secondaryChain.length}); need ≥2 on each side.`);\n    }\n    // ── Build the boundary drawing ─────────────────────────────────────────\n    // Primary chain (spline) → last ruling (straight) → reversed secondary\n    // chain (spline) → close back along first ruling (straight).\n    const pen = replicad.draw(primaryChain[0]);\n    for (let i = 1; i < primaryChain.length; i++) {\n        pen.lineTo(primaryChain[i]);\n    }\n    pen.lineTo(secondaryChain[secondaryChain.length - 1]);\n    for (let i = secondaryChain.length - 2; i >= 0; i--) {\n        pen.lineTo(secondaryChain[i]);\n    }\n    let drawing = pen.close();\n    // ── Punch holes from inner wires (if any) ───────────────────────\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const innerWires = face.clone().innerWires() ?? [];\n    for (let h = 0; h < innerWires.length; h++) {\n        const wire = innerWires[h];\n        // Pass 1: dense 3D samples around the wire.\n        const samples3D = [];\n        for (let i = 0; i < holeN; i++) {\n            const t = i / holeN;\n            samples3D.push(toT3(wire.pointAt(t)));\n        }\n        if (samples3D.length < 3)\n            continue;\n        // Pass 2: map 3D→2D using nearest physical triangle.\n        const samples2D = samples3D\n            .map((p) => {\n            const k = findBestTriangle3D(p, tris3D);\n            return k >= 0 ? mapWithTriangle3D(p, k, tris3D, tris2D) : null;\n        })\n            .filter((p) => p !== null);\n        if (samples2D.length < 3)\n            continue;\n        // Pass 3: Draw the hole.\n        const holePen = replicad.draw(samples2D[0]);\n        for (let i = 1; i < samples2D.length; i++) {\n            holePen.lineTo(samples2D[i]);\n        }\n        const holeDrawing = holePen.close();\n        drawing = drawing.cut(holeDrawing);\n    }\n    return new Assembly({\n        geometry: drawing,\n        color: \"#5B9BD5\",\n        tags: [\"developed\", \"ruling-primary:\" + pIdx],\n    });\n}\nfunction toT3(v) {\n    return [v.x, v.y, v.z];\n}\nfunction dist3(a, b) {\n    return Math.hypot(a[0] - b[0], a[1] - b[1], a[2] - b[2]);\n}\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction validateAndExtractFace(surface) {\n    if (!surface || !surface.isLeaf || !surface.isLeaf()) {\n        throw new Error(\"Unroll surface: input must be an Assembly with exactly one leaf \" +\n            \"(the ruled surface as a replicad.Face).\");\n    }\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const face = surface.geometry;\n    if (!(face instanceof replicad.Face)) {\n        throw new Error(\"Unroll surface: input geometry must be a replicad.Face; got \" +\n            (face && face.constructor ? face.constructor.name : typeof face));\n    }\n    return face;\n}\nfunction partitionOuterWire(\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nface, primaryEdgeIndex) {\n    const outerWire = face.clone().outerWire();\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const allEdges = outerWire.edges ?? [];\n    const m = allEdges.length;\n    const pIdx = ((Math.floor(primaryEdgeIndex) % m) + m) % m;\n    const primary = allEdges[pIdx];\n    const excludedIdx = new Set([pIdx]);\n    if (primary.isClosed) {\n        if (pIdx == 0) {\n            excludedIdx.add(1);\n        }\n        else if (pIdx == allEdges.length - 1) {\n            excludedIdx.add(allEdges.length - 2);\n        }\n        else {\n            console.warn(\"found a closed face with two neighbors..\");\n        }\n    }\n    else {\n        excludedIdx.add((pIdx - 1 + m) % m);\n        excludedIdx.add((pIdx + 1) % m);\n    }\n    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n    const secondaryEdges = [];\n    for (let k = 0; k < m; k++) {\n        const idx = (pIdx + 2 + k) % m;\n        if (!excludedIdx.has(idx))\n            secondaryEdges.push(allEdges[idx]);\n    }\n    if (secondaryEdges.length === 0) {\n        throw new Error(\"Unroll surface: no secondary edges remain after excluding primary \" +\n            \"and its two neighbours.\");\n    }\n    return { primary, secondaryEdges, pIdx };\n}\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction samplePrimary(primary, n) {\n    const out = new Array(n);\n    for (let i = 0; i < n; i++) {\n        const t = n === 1 ? 0 : i / (n - 1);\n        out[i] = toT3(primary.pointAt(t));\n    }\n    return out;\n}\nfunction sampleSecondary(\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nsecondaryEdges, n) {\n    const secLengths = secondaryEdges.map((e) => e.length);\n    const secTotal = secLengths.reduce((a, b) => a + b, 0);\n    if (!(secTotal > 0)) {\n        throw new Error(\"Unroll surface: secondary edges have zero total length.\");\n    }\n    const perEdge = secondaryEdges.map((_, k) => Math.max(1, Math.round((n * secLengths[k]) / secTotal)));\n    let perSum = perEdge.reduce((a, b) => a + b, 0);\n    while (perSum !== n) {\n        let bestK = 0;\n        let bestLen = -1;\n        for (let k = 0; k < secondaryEdges.length; k++) {\n            if (secLengths[k] > bestLen) {\n                bestLen = secLengths[k];\n                bestK = k;\n            }\n        }\n        if (perSum < n) {\n            perEdge[bestK] += 1;\n            perSum += 1;\n        }\n        else if (perEdge[bestK] > 1) {\n            perEdge[bestK] -= 1;\n            perSum -= 1;\n        }\n        else {\n            break;\n        }\n    }\n    const samples = [];\n    for (let k = 0; k < secondaryEdges.length; k++) {\n        const e = secondaryEdges[k];\n        const cnt = perEdge[k];\n        for (let i = 0; i < cnt; i++) {\n            const t = (i + 0.5) / cnt;\n            samples.push(toT3(e.pointAt(t)));\n        }\n    }\n    let cursor = 0;\n    for (let k = 0; k < secondaryEdges.length - 1; k++) {\n        cursor += perEdge[k];\n        const sharedVertex = toT3(secondaryEdges[k].endPoint);\n        const a = cursor - 1;\n        const b = cursor;\n        if (a < 0 || b >= samples.length)\n            continue;\n        const dA = dist3(samples[a], sharedVertex);\n        const dB = dist3(samples[b], sharedVertex);\n        if (dA <= dB)\n            samples[a] = sharedVertex;\n        else\n            samples[b] = sharedVertex;\n    }\n    return samples;\n}\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction normalAtSafe(face, p) {\n    try {\n        const nv = face.normalAt(p);\n        const x = nv.x, y = nv.y, z = nv.z;\n        const len = Math.hypot(x, y, z);\n        if (!(len > 0))\n            return null;\n        return [x / len, y / len, z / len];\n    }\n    catch {\n        return null;\n    }\n}\nfunction buildCostGrid(\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nface, primarySamples, secondarySamples) {\n    const n = primarySamples.length;\n    const ns = secondarySamples.length;\n    const primaryNormals = primarySamples.map((p) => normalAtSafe(face, p));\n    const secondaryNormals = secondarySamples.map((p) => normalAtSafe(face, p));\n    const cost = new Array(n);\n    for (let i = 0; i < n; i++) {\n        const row = new Array(ns);\n        const nA = primaryNormals[i];\n        for (let j = 0; j < ns; j++) {\n            const nB = secondaryNormals[j];\n            if (!nA || !nB) {\n                row[j] = Infinity;\n                continue;\n            }\n            const dot = nA[0] * nB[0] + nA[1] * nB[1] + nA[2] * nB[2];\n            row[j] = 1 - Math.abs(dot);\n        }\n        cost[i] = row;\n    }\n    return cost;\n}\nfunction quadTwist(P, S, i, j, iN, jN) {\n    const A = P[i];\n    const Ap = P[iN];\n    const B = S[j];\n    const Bp = S[jN];\n    const e1x = Ap[0] - A[0], e1y = Ap[1] - A[1], e1z = Ap[2] - A[2];\n    const e2x = Bp[0] - A[0], e2y = Bp[1] - A[1], e2z = Bp[2] - A[2];\n    const e3x = B[0] - A[0], e3y = B[1] - A[1], e3z = B[2] - A[2];\n    const nx = e1y * e2z - e1z * e2y;\n    const ny = e1z * e2x - e1x * e2z;\n    const nz = e1x * e2y - e1y * e2x;\n    const nMag = Math.hypot(nx, ny, nz);\n    const height = nMag > 0 ? Math.abs(nx * e3x + ny * e3y + nz * e3z) / nMag : 0;\n    const avgEdge = 0.25 * (dist3(A, Ap) + dist3(Ap, Bp) + dist3(Bp, B) + dist3(B, A));\n    return avgEdge > 0 ? height / avgEdge : 0;\n}\n/**\n * 2-neighbour anti-diagonal DP: from (i, j) you may only advance to\n * (i+1, j) or (i, j+1). Every path has 2(n-1) steps and emits 2n-1 rulings.\n * Identical to the implementation in atomimpl.ts.\n */\nfunction findOptimalRulingPath(cost, P, S) {\n    const n = cost.length;\n    const INF = Number.POSITIVE_INFINITY;\n    const dist = new Array(n);\n    const prevDir = new Array(n);\n    for (let i = 0; i < n; i++) {\n        dist[i] = new Array(n).fill(INF);\n        prevDir[i] = new Array(n).fill(-1);\n    }\n    dist[0][0] = cost[0][0];\n    for (let s = 1; s <= 2 * (n - 1); s++) {\n        const iLo = Math.max(0, s - (n - 1));\n        const iHi = Math.min(n - 1, s);\n        for (let iN = iLo; iN <= iHi; iN++) {\n            const jN = s - iN;\n            const rulingCost = cost[iN][jN];\n            if (!isFinite(rulingCost))\n                continue;\n            let best = INF;\n            let bestDir = -1;\n            if (iN > 0 && isFinite(dist[iN - 1][jN])) {\n                const cand = dist[iN - 1][jN] + rulingCost + quadTwist(P, S, iN - 1, jN, iN, jN);\n                if (cand < best) {\n                    best = cand;\n                    bestDir = 0;\n                }\n            }\n            if (jN > 0 && isFinite(dist[iN][jN - 1])) {\n                const cand = dist[iN][jN - 1] + rulingCost + quadTwist(P, S, iN, jN - 1, iN, jN);\n                if (cand < best) {\n                    best = cand;\n                    bestDir = 1;\n                }\n            }\n            if (best < INF) {\n                dist[iN][jN] = best;\n                prevDir[iN][jN] = bestDir;\n            }\n        }\n    }\n    const path = [];\n    if (isFinite(dist[n - 1][n - 1])) {\n        let ci = n - 1;\n        let cj = n - 1;\n        while (ci >= 0 && cj >= 0) {\n            path.push([ci, cj]);\n            if (ci === 0 && cj === 0)\n                break;\n            const dir = prevDir[ci][cj];\n            if (dir === 0)\n                ci -= 1;\n            else if (dir === 1)\n                cj -= 1;\n            else\n                break;\n        }\n        path.reverse();\n        return { path, totalCost: dist[n - 1][n - 1] };\n    }\n    console.warn(\"Unroll: DAG search found no path; falling back to diagonal.\");\n    for (let k = 0; k < n; k++)\n        path.push([k, k]);\n    return { path, totalCost: INF };\n}\n/**\n * Locate the unfold triangle whose plane is closest to `p`, returning the\n * 2D image of `p` under that triangle's affine 3D→2D map. We prefer\n * triangles where the projected point's barycentric coordinates are all\n * within [−ε, 1+ε] (i.e. inside the triangle); among those, pick the one\n * with the smallest perpendicular distance. If none qualify, fall back to\n * the globally closest triangle and clamp.\n */\n/**\n * Safely fetch the UV coordinates of a 3D point on `face`. Returns null if\n * the point is off-surface or OCCT raises (e.g. periodic-seam glitch).\n * `face.uvCoordinates(p)` may return either a `[u, v]` tuple or an\n * object with .u/.v depending on the replicad build; normalise both.\n */\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nfunction uvAtSafe(face, p) {\n    try {\n        const r = face.uvCoordinates([p[0], p[1], p[2]]);\n        if (Array.isArray(r)) {\n            if (!isFinite(r[0]) || !isFinite(r[1]))\n                return null;\n            return [r[0], r[1]];\n        }\n        if (r && typeof r.u === \"number\" && typeof r.v === \"number\") {\n            return [r.u, r.v];\n        }\n        return null;\n    }\n    catch {\n        return null;\n    }\n}\n/**\n * Return the index of the unfold triangle whose UV image contains `uv`,\n * or -1 if none does. UV is a single-valued chart on the trimmed face, so\n * at most one triangle truly contains `uv`; a small ε accepts on-edge\n * points and either side resolves to the same 2D position (the affine\n * maps agree on the shared edge).\n */\nfunction findContainingTriangle(uv, trisUV) {\n    const EPS = 1e-9;\n    for (let k = 0; k < trisUV.length; k++) {\n        const tri = trisUV[k];\n        if (!tri)\n            continue;\n        const bary = baryUV(uv, tri[0], tri[1], tri[2]);\n        if (!bary)\n            continue;\n        const [u, v, w] = bary;\n        if (u >= -EPS && v >= -EPS && w >= -EPS)\n            return k;\n    }\n    return -1;\n}\n/**\n * Identify the best 3D triangle for a point P. We prefer the one where P\n * projects inside (positive barycentric), using physical distance to the\n * triangle plane as a tie-breaker.\n */\nfunction findBestTriangle3D(p, tris3D) {\n    let bestK = -1;\n    let minScore = Infinity;\n    for (let k = 0; k < tris3D.length; k++) {\n        const tri = tris3D[k];\n        const bary = bary3D(p, tri[0], tri[1], tri[2]);\n        if (!bary)\n            continue;\n        const [u, v, w] = bary;\n        // Penalty for being physically outside the triangle footprint\n        const outsideDist = Math.max(0, -u, -v, -w);\n        // Distance to triangle plane\n        const planeDist = distToPlane(p, tri[0], tri[1], tri[2]);\n        // Combined score: proximity to plane + penalty for being outside.\n        // Being outside is penalized much more heavily than being slightly\n        // off-plane.\n        const score = planeDist + outsideDist * 1000;\n        if (score < minScore) {\n            minScore = score;\n            bestK = k;\n        }\n    }\n    return bestK;\n}\n/**\n * Project 3D point p into triangle k and return its 2D coordinates.\n */\nfunction mapWithTriangle3D(p, k, tris3D, tris2D) {\n    const tri3 = tris3D[k];\n    const tri2 = tris2D[k];\n    const bary = bary3D(p, tri3[0], tri3[1], tri3[2]);\n    if (!bary)\n        return [0, 0];\n    const [u, v, w] = bary;\n    const [a2, b2, c2] = tri2;\n    return [u * a2[0] + v * b2[0] + w * c2[0], u * a2[1] + v * b2[1] + w * c2[1]];\n}\nfunction distToPlane(p, a, b, c) {\n    const v1 = [b[0] - a[0], b[1] - a[1], b[2] - a[2]];\n    const v2 = [c[0] - a[0], c[1] - a[1], c[2] - a[2]];\n    const nx = v1[1] * v2[2] - v1[2] * v2[1];\n    const ny = v1[2] * v2[0] - v1[0] * v2[2];\n    const nz = v1[0] * v2[1] - v1[1] * v2[0];\n    const nLen = Math.hypot(nx, ny, nz);\n    if (nLen === 0)\n        return dist3(p, a);\n    const dx = p[0] - a[0];\n    const dy = p[1] - a[1];\n    const dz = p[2] - a[2];\n    return Math.abs(dx * nx + dy * ny + dz * nz) / nLen;\n}\n/**\n * 3D Barycentric coordinates of P in triangle (A, B, C).\n * P is projected onto the plane of ABC.\n */\nfunction bary3D(p, a, b, c) {\n    const v0 = [b[0] - a[0], b[1] - a[1], b[2] - a[2]];\n    const v1 = [c[0] - a[0], c[1] - a[1], c[2] - a[2]];\n    const v2 = [p[0] - a[0], p[1] - a[1], p[2] - a[2]];\n    const d00 = v0[0] * v0[0] + v0[1] * v0[1] + v0[2] * v0[2];\n    const d01 = v0[0] * v1[0] + v0[1] * v1[1] + v0[2] * v1[2];\n    const d11 = v1[0] * v1[0] + v1[1] * v1[1] + v1[2] * v1[2];\n    const d20 = v2[0] * v0[0] + v2[1] * v0[1] + v2[2] * v0[2];\n    const d21 = v2[0] * v1[0] + v2[1] * v1[1] + v2[2] * v1[2];\n    const denom = d00 * d11 - d01 * d01;\n    if (Math.abs(denom) < 1e-12)\n        return null;\n    const invDenom = 1.0 / denom;\n    const v = (d11 * d20 - d01 * d21) * invDenom;\n    const w = (d00 * d21 - d01 * d20) * invDenom;\n    const u = 1.0 - v - w;\n    return [u, v, w];\n}\n/**\n * Affine UV→2D map via the barycentric of `uv` in triangle `k`. Caller is\n * responsible for picking a triangle that (nearly) contains `uv`.\n */\nfunction mapWithTriangle(uv, k, trisUV, tris2D) {\n    const tri = trisUV[k];\n    if (!tri)\n        return [0, 0];\n    const bary = baryUV(uv, tri[0], tri[1], tri[2]);\n    const [u, v, w] = bary ?? [1, 0, 0];\n    const [a2, b2, c2] = tris2D[k];\n    return [u * a2[0] + v * b2[0] + w * c2[0], u * a2[1] + v * b2[1] + w * c2[1]];\n}\n/** Signed-area barycentric of `p` in triangle (A, B, C) in 2D. Returns\n *  [u, v, w] with u+v+w=1; null on a zero-area triangle. */\nfunction baryUV(p, A, B, C) {\n    const ax = B[0] - A[0], ay = B[1] - A[1];\n    const bx = C[0] - A[0], by = C[1] - A[1];\n    const denom = ax * by - ay * bx;\n    if (!(Math.abs(denom) > 0))\n        return null;\n    const px = p[0] - A[0], py = p[1] - A[1];\n    const v = (px * by - py * bx) / denom;\n    const w = (ax * py - ay * px) / denom;\n    const u = 1 - v - w;\n    return [u, v, w];\n}\n/** Place a new 2D point at distance r0 from p0 and r1 from p1, on the\n * sideSign side of the directed line p0→p1 (+1 = left, −1 = right). */\nfunction circleIntersect(p0, r0, p1, r1, sideSign, stripIdx) {\n    const dx = p1[0] - p0[0];\n    const dy = p1[1] - p0[1];\n    const d = Math.hypot(dx, dy);\n    const sum = r0 + r1;\n    const diff = Math.abs(r0 - r1);\n    const EPS = 1e-6;\n    if (d === 0 || d > sum * (1 + EPS) || d < diff * (1 - EPS)) {\n        throw new Error(`Unroll: degenerate triangle at strip ${stripIdx} ` +\n            `(r0=${r0.toFixed(4)}, r1=${r1.toFixed(4)}, hinge=${d.toFixed(4)}).`);\n    }\n    const dC = Math.max(diff, Math.min(sum, d));\n    const a = (r0 * r0 - r1 * r1 + dC * dC) / (2 * dC);\n    const h = Math.sqrt(Math.max(0, r0 * r0 - a * a));\n    const ux = dx / d;\n    const uy = dy / d;\n    const mx = p0[0] + a * ux;\n    const my = p0[1] + a * uy;\n    return [mx + h * -uy * sideSign, my + h * ux * sideSign];\n}\n"
        }
